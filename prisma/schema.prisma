generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model accountingPeriod {
  id         String    @id
  tenant_id  String
  name       String
  start_date DateTime
  end_date   DateTime
  status     String
  closed_at  DateTime?
  closed_by  String?
  created_at DateTime  @default(now())
  updated_at DateTime @default(now())

  @@unique([tenant_id, name])
  @@index([status])
  @@index([tenant_id])
  @@map("accounting_periods")
}

model adminAuditEvent {
  id          String   @id
  tenant_id   String
  action      String
  entity_type String
  entity_id   String
  actor_id    String
  created_at  DateTime @default(now())
  updated_at DateTime @default(now())

  @@map("admin_audit_events")
}

model adminModuleStatus {
  id         String   @id
  tenant_id  String
  module_key String
  enabled    Boolean  @default(true)
  updated_by String
  updated_at DateTime @default(now())

  @@unique([tenant_id, module_key])
  @@map("admin_module_statuses")
}

model adminRequest {
  id           String   @id
  tenant_id    String
  type         String
  title        String
  detail       String?
  status       String   @default("open")
  requested_by String
  created_at   DateTime @default(now())
  updated_at DateTime @default(now())
  resolved_by  String?

  @@map("admin_requests")
}

model agenticEvent {
  id              String    @id
  tenant_id       String
  event_type      String
  entity_id       String
  entity_type     String
  payload         Json
  status          String    @default("PENDING")
  processed_at    DateTime?
  error_msg       String?
  created_at      DateTime  @default(now())
  correlation_id  String?
  source_event_id String?
  company         company   @relation(fields: [tenant_id], references: [id])
  updated_at DateTime @default(now())

  @@index([tenant_id, entity_id])
  @@index([tenant_id, event_type, status])
  @@map("agentic_events")
}

model assetDepreciationEntry {
  id               String   @id
  tenant_id        String
  asset_id         String
  period           String
  date             DateTime
  depreciation_exp Decimal  @db.Decimal(15, 2)
  accumulated_dep  Decimal  @db.Decimal(15, 2)
  carrying_value   Decimal  @db.Decimal(15, 2)
  journal_ref      String?
  created_at       DateTime @default(now())
  updated_at DateTime @default(now())

  @@index([tenant_id, asset_id])
  @@map("asset_depreciation_entries")
}

model assetEvent {
  id          String   @id
  tenant_id   String
  asset_id    String
  type        String
  description String
  date        DateTime
  recorded_by String
  created_at  DateTime @default(now())
  updated_at DateTime @default(now())

  @@index([tenant_id, asset_id])
  @@map("asset_events")
}

model auditHashAnchor {
  id           String   @id
  tenant_id    String
  anchor_hash  String
  anchored_at  DateTime @default(now())
  record_count Int
  company      company  @relation(fields: [tenant_id], references: [id])
  updated_at DateTime @default(now())

  @@index([anchored_at])
  @@index([tenant_id])
  @@map("audit_hash_anchors")
}

model auditLog {
  id                 String   @id
  tenant_id          String
  module             String
  action             String
  entity_type        String
  entity_id          String
  user_id            String
  changes            Json?
  metadata           Json?
  created_at         DateTime @default(now())
  ip_address         String?
  severity           String   @default("INFO")
  user_agent         String?
  hash_chain         String?
  source_module      String?
  after_state        Json?
  before_state       Json?
  correlation_id     String?
  idempotency_key    String?
  original_hash      String?
  previous_hash      String?
  recomputed_hash    String?
  status             String   @default("NORMAL")
  event_reference_id String?
  company            company  @relation(fields: [tenant_id], references: [id])
  updated_at DateTime @default(now())

  @@unique([tenant_id, idempotency_key])
  @@index([created_at])
  @@index([module])
  @@index([tenant_id, entity_type, entity_id])
  @@index([tenant_id])
  @@index([tenant_id, source_module])
  @@index([user_id])
  @@map("audit_logs")
}

model bulletinCategory {
  id         String   @id
  tenant_id  String
  name       String
  code       String
  color      String?
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  company    company  @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, code])
  @@map("bulletin_categories")
}

model bulletinComment {
  id           String       @id
  post_id      String
  tenant_id    String
  author_id    String
  body         String
  created_at   DateTime     @default(now())
  deleted_at   DateTime?
  bulletinPost bulletinPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  company      company      @relation(fields: [tenant_id], references: [id])
  updated_at DateTime @default(now())

  @@index([tenant_id])
  @@map("bulletin_comments")
}

model bulletinPost {
  id               String             @id
  tenant_id        String
  author_id        String
  title            String
  body             String
  category         String             @default("general")
  attachments      Json?
  status           String             @default("published")
  is_pinned        Boolean            @default(false)
  pin_order        Int?
  scope_type       String             @default("company")
  scope_id         String?
  publish_at       DateTime?
  expires_at       DateTime?
  view_count       Int                @default(0)
  created_at       DateTime           @default(now())
  updated_at DateTime @default(now())
  deleted_at       DateTime?
  bulletinComment  bulletinComment[]
  company          company            @relation(fields: [tenant_id], references: [id])
  bulletinReaction bulletinReaction[]
  bulletinRead     bulletinRead[]

  @@index([status])
  @@index([tenant_id])
  @@map("bulletin_posts")
}

model bulletinReaction {
  id           String       @id
  post_id      String
  user_id      String
  created_at   DateTime     @default(now())
  tenant_id    String
  type         String       @default("LIKE")
  bulletinPost bulletinPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  company      company      @relation(fields: [tenant_id], references: [id])
  updated_at DateTime @default(now())

  @@unique([post_id, user_id, type])
  @@index([tenant_id])
  @@map("bulletin_reactions")
}

model bulletinRead {
  id           String       @id
  post_id      String
  user_id      String
  read_at      DateTime     @default(now())
  bulletinPost bulletinPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  updated_at DateTime @default(now())

  @@unique([post_id, user_id])
  @@map("bulletin_reads")
}

model candidate {
  id             String         @id
  tenant_id      String
  first_name     String
  last_name      String
  email          String
  phone          String?
  requisition_id String
  source         String
  status         String         @default("applied")
  resume_url     String?
  metadata       Json?
  created_at     DateTime       @default(now())
  updated_at DateTime @default(now())
  deleted_at     DateTime?
  jobRequisition jobRequisition @relation(fields: [requisition_id], references: [id])
  company        company        @relation(fields: [tenant_id], references: [id])
  interview      interview[]

  @@index([tenant_id])
  @@map("candidates")
}

model capexBudget {
  id               String   @id
  tenant_id        String
  department       String
  period           String
  allocated_budget Decimal  @db.Decimal(15, 2)
  committed_budget Decimal  @default(0) @db.Decimal(15, 2)
  available_budget Decimal  @db.Decimal(15, 2)
  created_at       DateTime @default(now())
  updated_at DateTime @default(now())

  @@unique([tenant_id, department, period])
  @@index([tenant_id])
  @@map("capex_budgets")
}

model capexRequest {
  id                     String       @id
  tenant_id              String
  asset_description      String
  requested_amount       Decimal      @db.Decimal(15, 2)
  department             String
  project_code           String?
  requested_by           String
  status                 String
  budget_matched         Boolean      @default(false)
  notes                  String?
  current_approval_stage String?
  created_at             DateTime     @default(now())
  updated_at DateTime @default(now())
  company                company      @relation(fields: [tenant_id], references: [id])
  fixedAsset             fixedAsset[]

  @@index([tenant_id])
  @@map("capex_requests")
}

model chatMember {
  id           String    @id
  room_id      String
  tenant_id    String
  user_id      String
  role         String    @default("member")
  joined_at    DateTime  @default(now())
  left_at      DateTime?
  muted_until  DateTime?
  last_read_at DateTime?
  unread_count Int       @default(0)
  chatRoom     chatRoom  @relation(fields: [room_id], references: [id], onDelete: Cascade)
  company      company   @relation(fields: [tenant_id], references: [id])
  user         user      @relation(fields: [user_id], references: [id])
  updated_at DateTime @default(now())

  @@unique([room_id, user_id])
  @@index([tenant_id])
  @@index([user_id])
  @@map("chat_members")
}

model chatReaction {
  id               String           @id
  message_id       String
  user_id          String
  emoji            String
  created_at       DateTime         @default(now())
  commsChatMessage commsChatMessage @relation(fields: [message_id], references: [id], onDelete: Cascade)
  updated_at DateTime @default(now())

  @@unique([message_id, user_id, emoji])
  @@map("chat_reactions")
}

model chatRoom {
  id                String             @id
  tenant_id         String
  name              String?
  type              ChatRoomType       @default(DIRECT)
  description       String?
  avatar_url        String?
  department_id     String?
  location_id       String?
  role_scope        String?
  created_by        String
  is_archived       Boolean            @default(false)
  created_at        DateTime           @default(now())
  updated_at DateTime @default(now())
  deleted_at        DateTime?
  direct_key        String?            @unique
  last_message_at   DateTime?
  last_message_id   String?
  last_message_text String?
  chatMember        chatMember[]
  department        department?        @relation(fields: [department_id], references: [id])
  location          location?          @relation(fields: [location_id], references: [id])
  company           company            @relation(fields: [tenant_id], references: [id])
  commsChatMessage  commsChatMessage[]

  @@index([direct_key])
  @@index([tenant_id, type])
  @@index([tenant_id, updated_at])
  @@map("chat_rooms")
}

model clinicReservation {
  id           String   @id
  tenant_id    String
  patient_id   String
  resource_id  String
  start_time   DateTime
  end_time     DateTime
  status       String   @default("PENDING")
  total_amount Decimal  @db.Decimal(15, 2)
  currency     String   @default("USD")
  created_at   DateTime @default(now())
  updated_at DateTime @default(now())
  company      company  @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, patient_id])
  @@index([tenant_id, resource_id, start_time])
  @@map("clinic_reservations")
}

model commsChatMessage {
  id                        String             @id
  room_id                   String
  tenant_id                 String
  sender_id                 String
  body                      String?
  type                      String?            @default("text")
  attachments               Json?
  ref_module                String?
  ref_entity_type           String?
  ref_entity_id             String?
  ref_label                 String?
  is_edited                 Boolean            @default(false)
  edited_at                 DateTime?
  deleted_at                DateTime?
  reply_to_id               String?
  created_at                DateTime           @default(now())
  delivered_at              DateTime?
  read_at                   DateTime?
  status                    MessageStatus      @default(SENT)
  event_reference_id        String?
  chatReaction              chatReaction[]
  commsChatMessage          commsChatMessage?  @relation("comms_chat_messagesTocomms_chat_messages", fields: [reply_to_id], references: [id])
  other_comms_chat_messages commsChatMessage[] @relation("comms_chat_messagesTocomms_chat_messages")
  chatRoom                  chatRoom           @relation(fields: [room_id], references: [id], onDelete: Cascade)
  company                   company            @relation(fields: [tenant_id], references: [id])
  updated_at DateTime @default(now())

  @@index([room_id, created_at])
  @@index([tenant_id])
  @@index([tenant_id, ref_module, ref_entity_type, ref_entity_id])
  @@map("comms_chat_messages")
}

