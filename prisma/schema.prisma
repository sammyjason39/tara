model Compensation {
  id             String    @id
  tenantId      String @map("tenant_id")
  employeeId    String    @unique @map("employee_id")
  baseSalary    Decimal   @db.Decimal(15, 2) @map("base_salary")
  currency       String    @default("USD")
  payFrequency  String    @default("monthly") @map("pay_frequency")
  allowances     Json?
  bonuses        Json?
  effectiveDate DateTime @map("effective_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  employee      Employee @relation(fields: [employeeId], references: [id])
  company      Company @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("compensations")
}

model Contract {
  id          String     @id @default(uuid())
  tenantId   String @map("tenant_id")
  employeeId String? @map("employee_id")
  title       String
  type        String
  status      String     @default("active")
  startDate  DateTime @map("start_date")
  endDate    DateTime? @map("end_date")
  url         String?
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  employee   Employee? @relation(fields: [employeeId], references: [id])
  company   Company  @relation(fields: [tenantId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([tenantId])
  @@map("contracts")
}

model CostLayer {
  id              String    @id
  tenantId       String @map("tenant_id")
  skuId          String @map("sku_id")
  locationId     String @map("location_id")
  qty             Decimal   @db.Decimal(15, 4)
  remainingQty   Decimal   @db.Decimal(15, 4) @map("remaining_qty")
  unitCost       Decimal   @db.Decimal(15, 2) @map("unit_cost")
  currency        String    @default("USD")
  method          String    @default("FIFO")
  sourceEventId String @map("source_event_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  company       Company @relation(fields: [tenantId], references: [id])

  @@index([tenantId, skuId, locationId])
  @@map("cost_layers")
}

model CostSnapshot {
  id              String    @id
  tenantId       String @map("tenant_id")
  skuId          String @map("sku_id")
  locationId     String @map("location_id")
  totalQty       Decimal   @db.Decimal(15, 4) @map("total_qty")
  totalValuation Decimal   @db.Decimal(15, 2) @map("total_valuation")
  avgUnitCost   Decimal   @db.Decimal(15, 2) @map("avg_unit_cost")
  currency        String    @default("USD")
