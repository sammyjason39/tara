  financeLedgerIdempotency          LedgerIdempotency[]
  financeLedgerPostingRules        LedgerPostingRule[]
  financeLedgerPostings             LedgerPosting[]
  financeTaxConfigs                 TaxConfig[]
  fixedAssets                        FixedAsset[]
  hrAttendanceRecords               HrAttendanceRecord[]
  hrBenefitPlans                    BenefitPlan[]
