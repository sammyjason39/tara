model SystemLog {
  id             String     @id @default(uuid())
  tenantId      String? @map("tenant_id")
  module         String
  level          String     @default("INFO")
  event          String
  message        String
  payload        Json?
  errorStack    String? @map("error_stack")
  requestId     String? @map("request_id")
  userId        String? @map("user_id")
  ipAddress     String? @map("ip_address")
  durationMs    Int? @map("duration_ms")
  createdAt     DateTime   @default(now()) @map("created_at")
  correlationId String? @map("correlation_id")
  company      Company? @relation(fields: [tenantId], references: [id])

  @@index([createdAt])
  @@index([level])
  @@index([module])
  @@index([tenantId])
  @@map("system_logs")
}

model TrainingAssignment {
  id                String            @id @default(uuid())
  tenantId         String @map("tenant_id")
  programId        String @map("program_id")
  employeeId       String @map("employee_id")
  status            String            @default("in_progress")
  assignedAt       DateTime @map("assigned_at")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  employee         Employee         @relation(fields: [employeeId], references: [id])
  trainingProgram TrainingProgram @relation(fields: [programId], references: [id])
  company         Company         @relation(fields: [tenantId], references: [id])

  @@index([employeeId])
  @@index([programId])
  @@index([tenantId])
  @@map("training_assignments")
}

model TrainingProgram {
  id                   String                 @id @default(uuid())
  tenantId            String @map("tenant_id")
  name                 String
  status               String                 @default("active")
  completionRate      Float                  @default(0) @map("completion_rate")
  dueDate             DateTime? @map("due_date")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")
  hrProgramSkills    ProgramSkill[]
  trainingAssignments TrainingAssignment[]
  company            Company              @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("training_programs")
}

model TreasuryTransfer {
  id             String    @id @default(uuid())
  tenantId      String @map("tenant_id")
  fromSourceId String @map("from_source_id")
  toSourceId   String @map("to_source_id")
  amount         Decimal   @db.Decimal(15, 2)
  currency       String    @default("IDR")
  status         String
  requestedBy   String @map("requested_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  company      Company @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("treasury_transfers")
}

model UserCompany {
  id         String    @id @default(uuid())
  userId    String @map("user_id")
  tenantId  String @map("tenant_id")
  role       String    @default("ADMIN")
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  company  Company @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("user_companies")
}

model UserNotificationPreference {
  id         String              @id
  tenantId  String @map("tenant_id")
  userId    String @map("user_id")
  module     String
  eventType String @map("event_type")
  channel    NotificationChannel
  enabled    Boolean             @default(true)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  company  Company           @relation(fields: [tenantId], references: [id])
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, module, eventType, channel])
  @@index([tenantId])
  @@index([tenantId, module, eventType])
  @@index([tenantId, userId])
  @@map("user_notification_preferences")
}

model User {
  id                            String                          @id @default(uuid())
  email                         String                          @unique
  passwordHash                 String @map("password_hash")
  firstName                    String @map("first_name")
  lastName                     String @map("last_name")
  phone                         String?
  status                        String                          @default("active")
  createdAt                    DateTime                        @default(now()) @map("created_at")
  updatedAt                    DateTime @default(now()) @updatedAt @map("updated_at")
  avatarUrl                    String? @map("avatar_url")
  tenantId                     String @map("tenant_id")
  chatMembers                  ChatMember[]
  userCompanies                UserCompany[]
  userNotificationPreferences UserNotificationPreference[]
  company                     Company                       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@map("users")
}

model WorkflowAuditEntry {
  id                String            @id @default(uuid())
  tenantId         String @map("tenant_id")
  workflowId       String @map("workflow_id")
  action            String
  actorId          String @map("actor_id")
  actorRole        String? @map("actor_role")
  notes             String?
  cycle             Int               @default(1)
  after             Json?
  createdAt        DateTime          @default(now()) @map("created_at")
  metadata          Json?
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  company         Company         @relation(fields: [tenantId], references: [id])
  workflowRequest WorkflowRequest @relation(fields: [workflowId], references: [id])

  @@index([tenantId])
  @@index([workflowId])
  @@map("workflow_audit_entries")
}

model WorkflowDefinition {
  id                 String               @id @default(uuid())
  tenantId          String @map("tenant_id")
  name               String
  description        String?
  steps              Json
  version            Int                  @default(1)
  active             Boolean              @default(true)
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  company          Company            @relation(fields: [tenantId], references: [id])
  workflowInstances WorkflowInstance[]

  @@unique([tenantId, name, version])
  @@map("workflow_definitions")
}

model WorkflowInstance {
  id                     String               @id @default(uuid())
  tenantId              String @map("tenant_id")
  workflowDefinitionId String @map("workflow_definition_id")
  correlationId         String               @unique @map("correlation_id")
  status                 String               @default("PENDING")
  currentState          String @map("current_state")
  context                Json
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")
  failureAt             DateTime? @map("failure_at")
  failureReason         String? @map("failure_reason")
  stepsExecuted         Json? @map("steps_executed")
  rootEventId          String? @map("root_event_id")
  company              Company            @relation(fields: [tenantId], references: [id])
  workflowDefinition   WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id])

  @@index([tenantId, status])
  @@map("workflow_instances")
}

model WorkflowRequest {
  id                     String                   @id @default(uuid())
  tenantId              String @map("tenant_id")
  entityType            String @map("entity_type")
  entityId              String @map("entity_id")
  makerDept             String @map("maker_dept")
  destinationDept       String @map("destination_dept")
  status                 String                   @default("PENDING")
  requestedBy           String? @map("requested_by")
  lastAction            String? @map("last_action")
  notes                  String?
  metadata               Json?
  cycle                  Int                      @default(1)
  steps                  Json?
  route                  Json?
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")
  financeArInvoices    ArInvoice[]
  payables               Payable[]
  paymentTransactions   PaymentTransaction[]
  workflowAuditEntries WorkflowAuditEntry[]
  company              Company                @relation(fields: [tenantId], references: [id])

  @@index([entityType, entityId])
  @@index([status])
  @@index([tenantId])
  @@map("workflow_requests")
}

