model CustomerCreditBalance {
  id          String   @id @default(uuid())
  tenantId   String @map("tenant_id")
  customerId String @map("customer_id")
  balance     Decimal  @default(0) @db.Decimal(19, 4)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, customerId])
  @@index([tenantId])
  @@map("customer_credit_balances")
}

model LedgerEventLog {
  id             String   @id @default(uuid())
  tenantId      String @map("tenant_id")
  companyId     String? @map("company_id")
  eventType     String @map("event_type")
  sourceEventId String @map("source_event_id")
  status         String   @default("PENDING")
  payload        Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, companyId, sourceEventId], name: "tenantId_companyId_sourceEventId")
  @@index([tenantId, status])
  @@index([tenantId, companyId, status])
  @@map("ledger_event_logs")
}
