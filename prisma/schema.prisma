  company                Company                  @relation(fields: [tenantId], references: [id])
  supplierPortalMessages SupplierPortalMessage[]
  supplierProducts        SupplierProduct[]

  @@index([supplierId])
  @@index([tenantId])
  @@map("supplier_branches")
}

model SupplierMaster {
  id                       String                     @id @default(uuid())
  tenantId                String @map("tenant_id")
  name                     String
  taxId                   String? @map("tax_id")
  complianceStatus        String                     @default("PENDING") @map("compliance_status")
  globalRating            Int                        @default(0) @map("global_rating")
