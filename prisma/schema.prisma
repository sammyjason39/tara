  company                                                     company     @relation(fields: [tenant_id], references: [id])
  departments_stock_movements_to_department_idTodepartments   department? @relation("stock_movements_to_department_idTodepartments", fields: [to_department_id], references: [id])
  locations_stock_movements_to_location_idTolocations         location?   @relation("stock_movements_to_location_idTolocations", fields: [to_location_id], references: [id])
  updated_at DateTime @default(now())

  @@unique([tenant_id, reference_id, reference_type, type, product_id, location_id])
  @@index([location_id])
  @@index([product_id])
  @@index([tenant_id])
  @@index([transfer_group_id])
  @@map("stock_movements")
}

