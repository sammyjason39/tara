model ModuleLicenseLog {
  id          String   @id @default(uuid())
  licenseId   String   @map("license_id")
  tenantId    String   @map("tenant_id")
  action      String
  performedBy String   @map("performed_by")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  license     ModuleLicense @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  company     Company       @relation(fields: [tenantId], references: [id])
  @@index([licenseId])
  @@index([tenantId])
  @@map("module_license_logs")
}

enum ChatRoomType {
  DIRECT
  GROUP
  DEPARTMENT
  LOCATION
  COMPANY
  ROLE
}

model ChatRoom {
  id           String       @id @default(uuid())
  tenantId     String       @map("tenant_id")
  name         String?
  type         ChatRoomType @default(DIRECT)
  description  String?
  avatarUrl    String?      @map("avatar_url")
  departmentId String?      @map("department_id")
  locationId   String?      @map("location_id")
  roleScope    String?      @map("role_scope")
  createdBy    String       @map("created_by")
  isArchived   Boolean      @default(false) @map("is_archived")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  company      Company      @relation(fields: [tenantId], references: [id])
  department   Department?  @relation(fields: [departmentId], references: [id])
  location     Location?    @relation(fields: [locationId], references: [id])
  members      ChatMember[]
  messages     ChatMessage[]
  @@index([tenantId])
  @@index([type])
  @@map("chat_rooms")
}

model ChatMember {
  id         String    @id @default(uuid())
  roomId     String    @map("room_id")
  tenantId   String    @map("tenant_id")
  userId     String    @map("user_id")
  role       String    @default("member")
  joinedAt   DateTime  @default(now()) @map("joined_at")
  leftAt     DateTime? @map("left_at")
  mutedUntil DateTime? @map("muted_until")
  lastReadAt DateTime? @map("last_read_at")
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  company    Company   @relation(fields: [tenantId], references: [id])
  @@unique([roomId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("chat_members")
}

model ChatMessage {
  id          String    @id @default(uuid())
  roomId      String    @map("room_id")
  tenantId    String    @map("tenant_id")
  senderId    String    @map("sender_id")
  body        String?
  type        String    @default("text")
  attachments Json?
  refModule   String?   @map("ref_module")
  refEntityId String?   @map("ref_entity_id")
  isEdited    Boolean   @default(false) @map("is_edited")
  editedAt    DateTime? @map("edited_at")
  deletedAt   DateTime? @map("deleted_at")
  replyToId   String?   @map("reply_to_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  room        ChatRoom      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  company     Company       @relation(fields: [tenantId], references: [id])
  replyTo     ChatMessage?  @relation("MessageReply", fields: [replyToId], references: [id])
  replies     ChatMessage[] @relation("MessageReply")
  reactions   ChatReaction[]
  @@index([tenantId])
  @@index([roomId])
  @@index([createdAt])
  @@map("chat_messages")
}

model ChatReaction {
  id        String      @id @default(uuid())
  messageId String      @map("message_id")
  userId    String      @map("user_id")
  emoji     String
  createdAt DateTime    @default(now()) @map("created_at")
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  @@unique([messageId, userId, emoji])
  @@map("chat_reactions")
}

model MailAccount {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  userId      String    @map("user_id")
  address     String
  type        String    @default("internal")
  displayName String?   @map("display_name")
  provider    String?
  smtpConfig  Json?     @map("smtp_config")
  isDefault   Boolean   @default(false) @map("is_default")
  isVerified  Boolean   @default(false) @map("is_verified")
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  company     Company   @relation(fields: [tenantId], references: [id])
  sent        MailMessage[]  @relation("SentMail")
  folders     MailFolder[]
  @@unique([userId, address])
  @@index([tenantId])
  @@map("mail_accounts")
}

model MailThread {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  subject   String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  company   Company   @relation(fields: [tenantId], references: [id])
  messages  MailMessage[]
  @@index([tenantId])
  @@map("mail_threads")
}

model MailMessage {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  threadId      String    @map("thread_id")
  fromAccountId String    @map("from_account_id")
  fromAddress   String    @map("from_address")
  toAddresses   Json      @map("to_addresses")
  ccAddresses   Json?     @map("cc_addresses")
  bccAddresses  Json?     @map("bcc_addresses")
  subject       String
  bodyHtml      String?   @map("body_html")
  bodyText      String?   @map("body_text")
  attachments   Json?
  status        String    @default("sent")
  isRead        Boolean   @default(false) @map("is_read")
  isStarred     Boolean   @default(false) @map("is_starred")
  sentAt        DateTime? @map("sent_at")
  receivedAt    DateTime? @map("received_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")
  company       Company     @relation(fields: [tenantId], references: [id])
  thread        MailThread  @relation(fields: [threadId], references: [id])
  fromAccount   MailAccount @relation("SentMail", fields: [fromAccountId], references: [id])
  labels        MailLabel[] @relation("MessageLabels")
  folderItems   MailFolderItem[]
  @@index([tenantId])
  @@index([threadId])
  @@map("mail_messages")
}

model MailFolder {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  name      String
  type      String   @default("custom")
  createdAt DateTime @default(now()) @map("created_at")
  account   MailAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  items     MailFolderItem[]
  @@unique([accountId, name])
  @@map("mail_folders")
}

model MailFolderItem {
  id        String @id @default(uuid())
  folderId  String @map("folder_id")
  messageId String @map("message_id")
  folder    MailFolder  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  message   MailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  @@unique([folderId, messageId])
  @@map("mail_folder_items")
}

model MailLabel {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  name     String
  color    String @default("#6366f1")
  company  Company      @relation(fields: [tenantId], references: [id])
  messages MailMessage[] @relation("MessageLabels")
  @@unique([tenantId, name])
  @@map("mail_labels")
}

model BulletinPost {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  authorId    String    @map("author_id")
  title       String
  body        String
  category    String    @default("general")
  attachments Json?
  status      String    @default("published")
  isPinned    Boolean   @default(false) @map("is_pinned")
  pinOrder    Int?      @map("pin_order")
  scopeType   String    @default("company")
  scopeId     String?   @map("scope_id")
  publishAt   DateTime? @map("publish_at")
  expiresAt   DateTime? @map("expires_at")
  viewCount   Int       @default(0) @map("view_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  company     Company   @relation(fields: [tenantId], references: [id])
  comments    BulletinComment[]
  reactions   BulletinReaction[]
  reads       BulletinRead[]
  @@index([tenantId])
  @@index([status])
  @@map("bulletin_posts")
}

model BulletinComment {
  id        String    @id @default(uuid())
  postId    String    @map("post_id")
  tenantId  String    @map("tenant_id")
  authorId  String    @map("author_id")
  body      String
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  post      BulletinPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  company   Company      @relation(fields: [tenantId], references: [id])
  @@index([tenantId])
  @@map("bulletin_comments")
}

model BulletinReaction {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  type      String   @default("LIKE")
  createdAt DateTime @default(now()) @map("created_at")
  post      BulletinPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  company   Company      @relation(fields: [tenantId], references: [id])
  @@unique([postId, userId, type])
  @@index([tenantId])
  @@map("bulletin_reactions")
}

model BulletinRead {
  id     String   @id @default(uuid())
  postId String   @map("post_id")
  userId String   @map("user_id")
  readAt DateTime @default(now()) @map("read_at")
  post   BulletinPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([postId, userId])
  @@map("bulletin_reads")
}

model BulletinCategory {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  code      String
  color     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  company   Company  @relation(fields: [tenantId], references: [id])
  @@unique([tenantId, code])
  @@map("bulletin_categories")
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  title     String
  message   String
  type      String   // INFO, ALERT, CHAT, MAIL, TASK
  link      String?  // Optional redirection link
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  company   Company  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId, isRead])
  @@map("notifications")
}
