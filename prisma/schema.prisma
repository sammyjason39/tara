  id                                  String                                @id
  name                                String
  code                                String                                @unique
  status                              String                                @default("active")
  createdAt                          DateTime                              @default(now()) @map("created_at")
  updatedAt                          DateTime @map("updated_at")
  deletedAt                          DateTime? @map("deleted_at")
  country                             String                                @default("US")
  currency                            String                                @default("USD")
  industry                            String                                @default("retail")
  agenticEvents                      AgenticEvent[]
  auditHashAnchors                  AuditHashAnchor[]
  auditLogs                          AuditLog[]
  bulletinCategories                 BulletinCategory[]
  bulletinComments                   BulletinComment[]
  bulletinPosts                      BulletinPost[]
  bulletinReactions                  BulletinReaction[]
  candidates                          Candidate[]
  capexRequests                      CapexRequest[]
  chatMembers                        ChatMember[]
  chatRooms                          ChatRoom[]
  commsChatMessages                 CommsChatMessage[]
  compensations                       Compensation[]
