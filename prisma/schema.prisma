  hrComplianceModules               HrComplianceModule[]
  hrComplianceReports               HrComplianceReport[]
  hrContextSnapshots                HrContextSnapshot[]
  hrEmployeeBenefits                EmployeeBenefit[]
  hrEmployeeSkills                  EmployeeSkill[]
  hrExchangeRates                   ExchangeRate[]
  hrHeadcountPlans                  HeadcountPlan[]
  hrHolidays                         HrHoliday[]
  hrInsights                         HrInsight[]
  hrMentorshipPairs                 MentorshipPair[]
  hrPayrollRuns                     PayrollRun[]
  hrPerformanceCycles               HrPerformanceCycle[]
  hrPerformanceGoals                PerformanceGoal[]
  hrPositionSkills                  PositionSkill[]
  hrProgramSkills                   ProgramSkill[]
  hrRecommendationFeedbacks         HrRecommendationFeedback[]
  hrRecommendations                  HrRecommendation[]
  hrSkills                           Skill[]
  hrSuccessionCandidates            SuccessionCandidate[]
  hrSuccessionPlans                 SuccessionPlan[]
  hrSystemAlerts                    HrSystemAlert[]
  hrSystemMetrics                   HrSystemMetric[]
  hrTalentLeads                     TalentLead[]
  hrThresholdAudits                 HrThresholdAudit[]
  hrWorkSchedules                   WorkSchedule[]
  interviews                          Interview[]
  inventoryAdjustments               InventoryAdjustment[]
  inventoryAlerts                    InventoryAlert[]
  inventoryAuditCycles              InventoryAuditCycle[]
  inventoryIntegrationEvents        InventoryIntegrationEvent[]
  inventoryMovementRequests         InventoryMovementRequest[]
  inventoryPools                     InventoryPool[]
  inventorySubledgerEntries         InventorySubledgerEntry[]
  itDeviceEvents                    ItDeviceEvent[]
  itDevices                          ItDevice[]
  itProvisioningRequests            ItProvisioningRequest[]
  itSettings                         ItSettings[]
  itSystemHealth                    ItSystemHealth[]
  itemMasters                        ItemMaster[]
  jobRequisitions                    JobRequisition[]
  jobRoles                           JobRole[]
  labelConfigs                       LabelConfig[]
  leaveRequests                      LeaveRequest[]
  locations                           Location[]
  mailAccounts                       MailAccount[]
  mailLabels                         MailLabel[]
  mailMessages                       MailMessage[]
  mailThreads                        MailThread[]
  marketingAccounts                  MarketingAccount[]
  marketingAlerts                    MarketingAlert[]
  marketingAttribution               MarketingAttribution[]
  marketingAuditEvents              MarketingAuditEvent[]
  marketingCampaigns                 MarketingCampaign[]
  marketingExecutions                MarketingExecution[]
  marketingLeads                     MarketingLead[]
  marketingWorkflows                 MarketingWorkflow[]
  moduleLicenseLogs                 ModuleLicenseLog[]
  moduleLicenses                     ModuleLicense[]
  moneySources                       MoneySource[]
  notifications                       Notification[]
