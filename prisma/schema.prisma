model compensation {
  id             String    @id
  tenant_id      String
  employee_id    String    @unique
  base_salary    Decimal   @db.Decimal(15, 2)
  currency       String    @default("USD")
  pay_frequency  String    @default("monthly")
  allowances     Json?
  bonuses        Json?
  effective_date DateTime
  created_at     DateTime  @default(now())
  updated_at DateTime @default(now())
  deleted_at     DateTime?
  employee       employee  @relation(fields: [employee_id], references: [id])
  company        company   @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("compensations")
}

model contract {
  id          String    @id
  tenant_id   String
  employee_id String?
  title       String
  type        String
  status      String    @default("active")
  start_date  DateTime
  end_date    DateTime?
  url         String?
  created_at  DateTime  @default(now())
  updated_at DateTime @default(now())
  employee    employee? @relation(fields: [employee_id], references: [id])
  company     company   @relation(fields: [tenant_id], references: [id])

  @@index([employee_id])
  @@index([status])
  @@index([tenant_id])
  @@map("contracts")
}

model costLayer {
  id              String   @id
  tenant_id       String
  sku_id          String
  location_id     String
  qty             Float
  remaining_qty   Float
  unit_cost       Decimal  @db.Decimal(15, 2)
  currency        String   @default("USD")
  method          String   @default("FIFO")
  source_event_id String
  created_at      DateTime @default(now())
  company         company  @relation(fields: [tenant_id], references: [id])
  updated_at DateTime @default(now())

  @@index([tenant_id, sku_id, location_id])
  @@map("cost_layers")
}

model costSnapshot {
  id              String   @id
  tenant_id       String
  sku_id          String
  location_id     String
  total_qty       Float
  total_valuation Decimal  @db.Decimal(15, 2)
  avg_unit_cost   Decimal  @db.Decimal(15, 2)
  currency        String   @default("USD")
  snapshot_date   DateTime @default(now())
  company         company  @relation(fields: [tenant_id], references: [id])
  updated_at DateTime @default(now())

  @@index([tenant_id, sku_id, location_id])
  @@map("cost_snapshots")
}

model department {
  id                                                              String                   @id
  tenant_id                                                       String
  name                                                            String
  code                                                            String
  head_id                                                         String?
  description                                                     String?
  status                                                          String                   @default("active")
  created_at                                                      DateTime                 @default(now())
  updated_at DateTime @default(now())
  deleted_at                                                      DateTime?
  chatRoom                                                        chatRoom[]
  company                                                         company                  @relation(fields: [tenant_id], references: [id])
  employee                                                        employee[]
  financeBudgetActual                                             financeBudgetActual[]
  financeBudgetLine                                               financeBudgetLine[]
  hrCa                                                            hrCa[]
  hrHeadcountPlan                                                 hrHeadcountPlan[]
  hrWorkSchedule                                                  hrWorkSchedule[]
  inventoryAdjustment                                             inventoryAdjustment[]
  itemMaster                                                      itemMaster[]
  jobRequisition                                                  jobRequisition[]
  leaveRequest                                                    leaveRequest[]
  paymentTransaction                                              paymentTransaction[]
  position                                                        position[]
  procurementRequisition                                          procurementRequisition[]
  stockLevel                                                      stockLevel[]
  stock_movements_stock_movements_department_idTodepartments      stockMovement[]          @relation("stock_movements_department_idTodepartments")
  stock_movements_stock_movements_from_department_idTodepartments stockMovement[]          @relation("stock_movements_from_department_idTodepartments")
  stock_movements_stock_movements_to_department_idTodepartments   stockMovement[]          @relation("stock_movements_to_department_idTodepartments")

  @@unique([tenant_id, code])
  @@index([status])
  @@index([tenant_id])
