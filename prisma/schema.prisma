generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AccountingPeriod {
  id         String    @id @default(uuid())
  tenantId  String @map("tenant_id")
  name       String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  status     String
  closedAt  DateTime? @map("closed_at")
  closedBy  String? @map("closed_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([tenantId, name])
  @@index([status])
  @@index([tenantId])
  @@map("accounting_periods")
}

model AdminAuditEvent {
  id          String   @id
  tenantId   String @map("tenant_id")
  action      String
  entityType String @map("entity_type")
  entityId   String @map("entity_id")
  actorId    String @map("actor_id")
  createdAt  DateTime @default(now()) @map("created_at")
  @@map("admin_audit_events")
}

model AdminModuleStatus {
  id         String   @id
  tenantId  String @map("tenant_id")
  moduleKey String @map("module_key")
  enabled    Boolean  @default(true)
  updatedBy String @map("updated_by")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([tenantId, moduleKey])
  @@map("admin_module_statuses")
}

model AdminRequest {
  id           String   @id
  tenantId    String @map("tenant_id")
  type         String
  title        String
  detail       String?
  status       String   @default("open")
  requestedBy String @map("requested_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @map("updated_at")
  resolvedBy  String? @map("resolved_by")
  @@map("admin_requests")
}

model AgenticEvent {
  id              String    @id
  tenantId       String @map("tenant_id")
  eventType      String @map("event_type")
  entityId       String @map("entity_id")
  entityType     String @map("entity_type")
  payload         Json
  status          String    @default("PENDING")
  processedAt    DateTime? @map("processed_at")
  errorMsg       String? @map("error_msg")
  createdAt      DateTime  @default(now()) @map("created_at")
  correlationId  String? @map("correlation_id")
  sourceEventId String? @map("source_event_id")
  company       Company @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entityId])
  @@index([tenantId, eventType, status])
  @@map("agentic_events")
}

model AssetDepreciationEntry {
  id               String   @id
  tenantId        String @map("tenant_id")
  assetId         String @map("asset_id")
  period           String
  date             DateTime
  depreciationExp Decimal  @db.Decimal(15, 2) @map("depreciation_exp")
  accumulatedDep  Decimal  @db.Decimal(15, 2) @map("accumulated_dep")
  carryingValue   Decimal  @db.Decimal(15, 2) @map("carrying_value")
  journalRef      String? @map("journal_ref")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([tenantId, assetId])
  @@map("asset_depreciation_entries")
}

model AssetEvent {
  id          String   @id
  tenantId   String @map("tenant_id")
  assetId    String @map("asset_id")
  type        String
  description String
  date        DateTime
  recordedBy String @map("recorded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, assetId])
  @@map("asset_events")
}

model AuditHashAnchor {
  id           String    @id
  tenantId    String @map("tenant_id")
  anchorHash  String @map("anchor_hash")
  anchoredAt  DateTime  @default(now()) @map("anchored_at")
  recordCount Int @map("record_count")
  company    Company @relation(fields: [tenantId], references: [id])

  @@index([anchoredAt])
  @@index([tenantId])
  @@map("audit_hash_anchors")
}

model AuditLog {
  id                 String    @id
  tenantId          String @map("tenant_id")
  module             String
  action             String
  entityType        String @map("entity_type")
  entityId          String @map("entity_id")
  userId            String @map("user_id")
  changes            Json?
  metadata           Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  ipAddress         String? @map("ip_address")
  severity           String    @default("INFO")
  userAgent         String? @map("user_agent")
  hashChain         String? @map("hash_chain")
  sourceModule      String? @map("source_module")
  afterState        Json? @map("after_state")
  beforeState       Json? @map("before_state")
  correlationId     String? @map("correlation_id")
  idempotencyKey    String? @map("idempotency_key")
  originalHash      String? @map("original_hash")
  previousHash      String? @map("previous_hash")
  recomputedHash    String? @map("recomputed_hash")
  status             String    @default("NORMAL")
  eventReferenceId String? @map("event_reference_id")
  company          Company @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([createdAt])
  @@index([module])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId])
  @@index([tenantId, sourceModule])
  @@index([userId])
  @@map("audit_logs")
}

model BulletinCategory {
  id         String    @id @default(uuid())
  tenantId  String @map("tenant_id")
  name       String
  code       String
  color      String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  company  Company @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@map("bulletin_categories")
}

model BulletinComment {
  id             String         @id
  postId        String @map("post_id")
  tenantId      String @map("tenant_id")
  authorId      String @map("author_id")
  body           String
  createdAt     DateTime       @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")
  bulletinPost BulletinPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("bulletin_comments")
}

model BulletinPost {
  id                 String               @id
  tenantId          String @map("tenant_id")
  authorId          String @map("author_id")
  title              String
  body               String
  category           String               @default("general")
  attachments        Json?
  status             String               @default("published")
  isPinned          Boolean              @default(false) @map("is_pinned")
  pinOrder          Int? @map("pin_order")
  scopeType          String               @default("company")
  scopeId           String? @map("scope_id")
  publishAt         DateTime? @map("publish_at")
  expiresAt         DateTime? @map("expires_at")
  viewCount         Int                  @default(0) @map("view_count")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  bulletinComments  BulletinComment[]
  company          Company            @relation(fields: [tenantId], references: [id])
  bulletinReactions BulletinReaction[]
  bulletinReads     BulletinRead[]

  @@index([status])
  @@index([tenantId])
  @@map("bulletin_posts")
}

model BulletinReaction {
  id             String         @id
  postId        String @map("post_id")
  userId        String @map("user_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  tenantId      String @map("tenant_id")
  type           String         @default("LIKE")
  bulletinPost BulletinPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [tenantId], references: [id])

  @@unique([postId, userId, type])
  @@index([tenantId])
  @@map("bulletin_reactions")
}

model BulletinRead {
  id             String         @id
  postId        String @map("post_id")
  userId        String @map("user_id")
  readAt        DateTime       @default(now()) @map("read_at")
  bulletinPost BulletinPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("bulletin_reads")
}

model Candidate {
  id               String           @id @default(uuid())
  tenantId        String @map("tenant_id")
  firstName       String @map("first_name")
  lastName        String @map("last_name")
  email            String
  phone            String?
  requisitionId   String @map("requisition_id")
  source           String
  status           String           @default("applied")
  resumeUrl       String? @map("resume_url")
  metadata         Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  jobRequisition JobRequisition @relation(fields: [requisitionId], references: [id])
  company        Company        @relation(fields: [tenantId], references: [id])
  interviews       Interview[]

  @@index([tenantId])
  @@map("candidates")
}

model CapexBudget {
  id               String   @id
  tenantId        String @map("tenant_id")
  department       String
  period           String
  allocatedBudget Decimal  @db.Decimal(15, 2) @map("allocated_budget")
  committedBudget Decimal  @default(0) @db.Decimal(15, 2) @map("committed_budget")
  availableBudget Decimal  @db.Decimal(15, 2) @map("available_budget")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @map("updated_at")

  @@unique([tenantId, department, period])
  @@index([tenantId])
  @@map("capex_budgets")
}

model CapexRequest {
  id                     String         @id
  tenantId              String @map("tenant_id")
  assetDescription      String @map("asset_description")
  requestedAmount       Decimal        @db.Decimal(15, 2) @map("requested_amount")
  department             String
  projectCode           String? @map("project_code")
  requestedBy           String @map("requested_by")
  status                 String
  budgetMatched         Boolean        @default(false) @map("budget_matched")
  notes                  String?
  currentApprovalStage String? @map("current_approval_stage")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime @map("updated_at")
  company              Company      @relation(fields: [tenantId], references: [id])
  fixedAssets           FixedAsset[]

  @@index([tenantId])
  @@map("capex_requests")
}

model ChatMember {
  id           String     @id
  roomId      String @map("room_id")
  tenantId    String @map("tenant_id")
  userId      String @map("user_id")
  role         String     @default("member")
  joinedAt    DateTime   @default(now()) @map("joined_at")
  leftAt      DateTime? @map("left_at")
  mutedUntil  DateTime? @map("muted_until")
  lastReadAt DateTime? @map("last_read_at")
  unreadCount Int        @default(0) @map("unread_count")
  chatRoom   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [tenantId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("chat_members")
}

model ChatReaction {
  id                  String              @id
  messageId          String @map("message_id")
  userId             String @map("user_id")
  emoji               String
  createdAt          DateTime            @default(now()) @map("created_at")
  commsChatMessage CommsChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("chat_reactions")
}

model ChatRoom {
  id                  String                @id
  tenantId           String @map("tenant_id")
  name                String?
  type                ChatRoomType          @default(DIRECT)
  description         String?
  avatarUrl          String? @map("avatar_url")
  departmentId       String? @map("department_id")
  locationId         String? @map("location_id")
  roleScope          String? @map("role_scope")
  createdBy          String @map("created_by")
  isArchived         Boolean               @default(false) @map("is_archived")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")
  directKey          String?               @unique @map("direct_key")
  lastMessageAt     DateTime? @map("last_message_at")
  lastMessageId     String? @map("last_message_id")
  lastMessageText   String? @map("last_message_text")
  chatMembers        ChatMember[]
  department         Department?          @relation(fields: [departmentId], references: [id])
  location           Location?            @relation(fields: [locationId], references: [id])
  company           Company             @relation(fields: [tenantId], references: [id])
  commsChatMessages CommsChatMessage[]

  @@index([directKey])
  @@index([tenantId, type])
  @@index([tenantId, updatedAt])
  @@map("chat_rooms")
}

model CommsChatMessage {
  id                        String                @id
  roomId                   String @map("room_id")
  tenantId                 String @map("tenant_id")
  senderId                 String @map("sender_id")
  body                      String?
  type                      String?               @default("text")
  attachments               Json?
  refModule                String? @map("ref_module")
  refEntityType           String? @map("ref_entity_type")
  refEntityId             String? @map("ref_entity_id")
  refLabel                 String? @map("ref_label")
  isEdited                 Boolean               @default(false) @map("is_edited")
  editedAt                 DateTime? @map("edited_at")
  deletedAt                DateTime? @map("deleted_at")
  replyToId               String? @map("reply_to_id")
  createdAt                DateTime              @default(now()) @map("created_at")
  deliveredAt              DateTime? @map("delivered_at")
  readAt                   DateTime? @map("read_at")
  status                    MessageStatus         @default(SENT)
  eventReferenceId        String? @map("event_reference_id")
  chatReactions            ChatReaction[]
  commsChatMessage       CommsChatMessage?  @relation("comms_chat_messagesTocomms_chat_messages", fields: [replyToId], references: [id])
  otherCommsChatMessages CommsChatMessage[] @relation("comms_chat_messagesTocomms_chat_messages")
  chatRoom                ChatRoom            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  company                 Company             @relation(fields: [tenantId], references: [id])

  @@index([roomId, createdAt])
  @@index([tenantId])
  @@index([tenantId, refModule, refEntityType, refEntityId])
  @@map("comms_chat_messages")
}

