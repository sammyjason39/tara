  tenantId  String @map("tenant_id")
  title      String
  type       String
  value      Decimal   @db.Decimal(15, 2)
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  status     String    @default("draft")
  target     String    @default("all")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  company  Company @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, title])
  @@index([status])
  @@index([tenantId])
  @@map("retail_promotions")
}

model RetailShift {
  id            String    @id @default(uuid())
  tenantId     String @map("tenant_id")
  storeId      String @map("store_id")
  employeeId   String @map("employee_id")
  startTime    DateTime @map("start_time")
  endTime      DateTime? @map("end_time")
  openingCash  Decimal   @db.Decimal(15, 2) @map("opening_cash")
  closingCash  Decimal?  @db.Decimal(15, 2) @map("closing_cash")
  expectedCash Decimal?  @db.Decimal(15, 2) @map("expected_cash")
  status        String    @default("open")
  notes         String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  employee     Employee @relation(fields: [employeeId], references: [id])
  store        Store    @relation(fields: [storeId], references: [id])
  company     Company @relation(fields: [tenantId], references: [id])

  @@index([employeeId])
  @@index([storeId])
  @@index([tenantId])
  @@map("retail_shifts")
}

model RetailWishlistItem {
  id               String           @id @default(uuid())
  wishlistId      String @map("wishlist_id")
  productId       String @map("product_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  itemMaster     ItemMaster     @relation(fields: [productId], references: [id])
  retailWishlist RetailWishlist @relation(fields: [wishlistId], references: [id])

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@map("retail_wishlist_items")
}

model RetailWishlist {
  id                    String                  @id @default(uuid())
  tenantId             String @map("tenant_id")
  customerId           String                  @unique @map("customer_id")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")
  retailWishlistItems RetailWishlistItem[]
  retailCustomer      RetailCustomer        @relation(fields: [customerId], references: [id])
  company             Company               @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("retail_wishlists")
}

model SalesAlert {
  id           String    @id @default(uuid())
  tenantId    String @map("tenant_id")
  type         String
  severity     String    @default("MEDIUM")
  entityType  String @map("entity_type")
  entityId    String @map("entity_id")
  message      String
  acknowledged Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  company    Company @relation(fields: [tenantId], references: [id])

  @@index([acknowledged])
  @@index([tenantId])
  @@map("sales_alerts")
}

model SalesAuditEvent {
  id          String    @id @default(uuid())
  tenantId   String @map("tenant_id")
  actorId    String @map("actor_id")
  action      String
  entityType String @map("entity_type")
  entityId   String @map("entity_id")
  detail      String
  createdAt  DateTime  @default(now()) @map("created_at")
  company   Company @relation(fields: [tenantId], references: [id])

  @@index([entityId])
  @@index([tenantId])
  @@map("sales_audit_events")
}

model SalesLead {
  id                    String                  @id @default(uuid())
  tenantId             String @map("tenant_id")
  companyName          String @map("company_name")
  contactName          String @map("contact_name")
  contactEmail         String? @map("contact_email")
  contactPhone         String? @map("contact_phone")
  source                String                  @default("MARKETING")
  ownerId              String @map("owner_id")
  ownerName            String @map("owner_name")
  score                 Int                     @default(0)
  potentialValue       Decimal                 @db.Decimal(15, 2) @map("potential_value")
  currency              String                  @default("IDR")
  priority              String                  @default("MEDIUM")
  status                String                  @default("NEW")
  slaDueAt            DateTime @map("sla_due_at")
  firstResponseAt     DateTime? @map("first_response_at")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")
  company             Company               @relation(fields: [tenantId], references: [id])
  salesOpportunities   SalesOpportunity[]
  salesTasks           SalesTask[]
  salesTimelineEvents SalesTimelineEvent[]

  @@index([status])
  @@index([tenantId])
  @@map("sales_leads")
}

model SalesOpportunity {
  id                    String                  @id @default(uuid())
  tenantId             String @map("tenant_id")
  leadId               String? @map("lead_id")
  accountName          String @map("account_name")
  ownerId              String @map("owner_id")
  ownerName            String @map("owner_name")
  stage                 String                  @default("NEW")
  probability           Int                     @default(0)
  amount                Decimal                 @db.Decimal(15, 2)
  currency              String                  @default("IDR")
  expectedCloseDate   DateTime @map("expected_close_date")
  health                String                  @default("MEDIUM_RISK")
  nextAction           String? @map("next_action")
  lastActivityAt      DateTime                @default(now()) @map("last_activity_at")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")
  salesLead           SalesLead?            @relation(fields: [leadId], references: [id])
  company             Company               @relation(fields: [tenantId], references: [id])
  salesOrders          SalesOrder[]
  salesQuotes          SalesQuote[]
  salesTasks           SalesTask[]
  salesTimelineEvents SalesTimelineEvent[]

  @@index([stage])
  @@index([tenantId])
  @@map("sales_opportunities")
}

model SalesOrder {
  id                  String              @id @default(uuid())
  tenantId           String @map("tenant_id")
  opportunityId      String @map("opportunity_id")
  quoteId            String? @map("quote_id")
  customerName       String @map("customer_name")
  amount              Decimal             @db.Decimal(15, 2)
  currency            String              @default("IDR")
  status              String              @default("DRAFT")
  inventoryCheck     String              @default("AVAILABLE") @map("inventory_check")
  financeInvoiceId  String? @map("finance_invoice_id")
  createdBy          String @map("created_by")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")
  salesOpportunity SalesOpportunity @relation(fields: [opportunityId], references: [id])
  salesQuote        SalesQuote?       @relation(fields: [quoteId], references: [id])
  company           Company           @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@index([tenantId])
  @@map("sales_orders")
}

model SalesQuote {
  id                  String              @id @default(uuid())
  tenantId           String @map("tenant_id")
  opportunityId      String @map("opportunity_id")
  accountName        String @map("account_name")
  version             Int                 @default(1)
  amount              Decimal             @db.Decimal(15, 2)
  discountPercent    Decimal             @default(0) @db.Decimal(5, 2) @map("discount_percent")
  netAmount          Decimal             @db.Decimal(15, 2) @map("net_amount")
  currency            String              @default("IDR")
  status              String              @default("DRAFT")
  validUntil         DateTime @map("valid_until")
  approvalBy         String? @map("approval_by")
  approvalAt         DateTime? @map("approval_at")
  notes               String?
  createdBy          String @map("created_by")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")
  salesOrders        SalesOrder[]
  salesOpportunity SalesOpportunity @relation(fields: [opportunityId], references: [id])
  company           Company           @relation(fields: [tenantId], references: [id])

  @@index([opportunityId])
  @@index([tenantId])
  @@map("sales_quotes")
}

model SalesTask {
  id                  String               @id @default(uuid())
  tenantId           String @map("tenant_id")
  opportunityId      String? @map("opportunity_id")
  leadId             String? @map("lead_id")
  title               String
  ownerId            String @map("owner_id")
  ownerName          String @map("owner_name")
  status              String               @default("PENDING")
  priority            String               @default("MEDIUM")
  dueAt              DateTime @map("due_at")
  completedAt        DateTime? @map("completed_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")
  salesLead         SalesLead?         @relation(fields: [leadId], references: [id])
  salesOpportunity SalesOpportunity? @relation(fields: [opportunityId], references: [id])
  company           Company            @relation(fields: [tenantId], references: [id])

  @@index([ownerId])
  @@index([tenantId])
  @@map("sales_tasks")
}

model SalesTimelineEvent {
  id                  String              @id @default(uuid())
  tenantId           String @map("tenant_id")
  opportunityId      String @map("opportunity_id")
  leadId             String? @map("lead_id")
  channel             String              @default("NOTE")
  direction           String              @default("INTERNAL")
  summary             String
  detail              String?
  createdBy          String @map("created_by")
  createdAt          DateTime            @default(now()) @map("created_at")
  salesLead         SalesLead?        @relation(fields: [leadId], references: [id])
  salesOpportunity SalesOpportunity @relation(fields: [opportunityId], references: [id])
  company           Company           @relation(fields: [tenantId], references: [id])

  @@index([opportunityId])
  @@index([tenantId])
  @@map("sales_timeline_events")
}

model ScheduleAssignment {
  id             String    @id @default(uuid())
  tenantId      String @map("tenant_id")
  employeeId    String @map("employee_id")
  shiftId       String @map("shift_id")
  locationId    String @map("location_id")
  effectiveDate DateTime @map("effective_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  employee      Employee @relation(fields: [employeeId], references: [id])
  location      Location @relation(fields: [locationId], references: [id])
  shift         Shift    @relation(fields: [shiftId], references: [id])
  company      Company @relation(fields: [tenantId], references: [id])

  @@index([employeeId])
  @@index([tenantId])
  @@map("schedule_assignments")
}

model SettlementRecord {
  id         String    @id @default(uuid())
  tenantId  String @map("tenant_id")
  sourceId  String @map("source_id")
  amount     Decimal   @db.Decimal(15, 2)
  currency   String    @default("IDR")
  status     String
  reference  String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  company  Company @relation(fields: [tenantId], references: [id])

  @@index([sourceId])
  @@index([tenantId])
  @@map("settlement_records")
}

model ShiftSwapRequest {
  id           String    @id @default(uuid())
  tenantId    String @map("tenant_id")
  requesterId String @map("requester_id")
  targetId    String @map("target_id")
  shiftId     String @map("shift_id")
  status       String    @default("pending")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  company    Company @relation(fields: [tenantId], references: [id])
  @@map("shift_swap_requests")
}

model Shift {
  id                    String                  @id @default(uuid())
  tenantId             String @map("tenant_id")
  name                  String
  startTime            String @map("start_time")
  endTime              String @map("end_time")
  breakDuration        Int                     @default(0) @map("break_duration")
  flexibleWindow       Int                     @default(0) @map("flexible_window")
  workDays             Int[] @map("work_days")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")
  hrAttendanceRecords HrAttendanceRecord[]
  scheduleAssignments  ScheduleAssignment[]
  company             Company               @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("shifts")
}

model StockLevel {
  id                 String       @id @default(uuid())
  tenantId          String @map("tenant_id")
  locationId        String @map("location_id")
  productId         String @map("product_id")
  onHand            Float        @default(0) @map("on_hand")
  reserved           Float        @default(0)
  available          Float        @default(0)
  minBuffer         Float        @default(0) @map("min_buffer")
  maxCapacity       Float        @default(0) @map("max_capacity")
  lastStockTakeAt DateTime? @map("last_stock_take_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  departmentId      String? @map("department_id")
  inTransit         Float        @default(0) @map("in_transit")
  department        Department? @relation(fields: [departmentId], references: [id])
  location          Location    @relation(fields: [locationId], references: [id])
  itemMaster       ItemMaster @relation(fields: [productId], references: [id])
  company          Company    @relation(fields: [tenantId], references: [id])

  @@unique([locationId, productId, departmentId])
  @@index([tenantId])
  @@map("stock_levels")
}

model StockMovement {
  id                                                          String       @id @default(uuid())
  tenantId                                                   String @map("tenant_id")
  productId                                                  String @map("product_id")
  fromLocationId                                            String? @map("from_location_id")
  toLocationId                                              String? @map("to_location_id")
  quantity                                                    Float
  type                                                        String
  referenceId                                                String @map("reference_id")
  performedBy                                                String @map("performed_by")
  createdAt                                                  DateTime     @default(now()) @map("created_at")
  fromDepartmentId                                          String? @map("from_department_id")
  toDepartmentId                                            String? @map("to_department_id")
  referenceType                                              String? @map("reference_type")
  departmentId                                               String? @map("department_id")
  locationId                                                 String @map("location_id")
  transferGroupId                                           String? @map("transfer_group_id")
  expiresAt                                                  DateTime? @map("expires_at")
  reservationId                                              String? @map("reservation_id")
  departments_stock_movements_department_idTodepartments      Department? @relation("stock_movements_department_idTodepartments", fields: [departmentId], references: [id])
  departments_stock_movements_from_department_idTodepartments Department? @relation("stock_movements_from_department_idTodepartments", fields: [fromDepartmentId], references: [id])
  locations_stock_movements_from_location_idTolocations       Location?   @relation("stock_movements_from_location_idTolocations", fields: [fromLocationId], references: [id])
  locations_stock_movements_location_idTolocations            Location    @relation("stock_movements_location_idTolocations", fields: [locationId], references: [id])
  itemMaster                                                ItemMaster @relation(fields: [productId], references: [id])
  company                                                   Company    @relation(fields: [tenantId], references: [id])
  departments_stock_movements_to_department_idTodepartments   Department? @relation("stock_movements_to_department_idTodepartments", fields: [toDepartmentId], references: [id])
  locations_stock_movements_to_location_idTolocations         Location?   @relation("stock_movements_to_location_idTolocations", fields: [toLocationId], references: [id])

  @@unique([tenantId, referenceId, referenceType, type, productId, locationId])
  @@index([locationId])
  @@index([productId])
  @@index([tenantId])
  @@index([transferGroupId])
  @@map("stock_movements")
}

model StockReservation {
  id             String       @id @default(uuid())
  tenantId      String @map("tenant_id")
  productId     String @map("product_id")
  locationId    String @map("location_id")
  quantity       Float
  status         String       @default("PENDING")
  referenceId   String @map("reference_id")
  referenceType String? @map("reference_type")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  location      Location    @relation(fields: [locationId], references: [id])
  itemMaster   ItemMaster @relation(fields: [productId], references: [id])
  company      Company    @relation(fields: [tenantId], references: [id])

  @@index([expiresAt])
  @@index([tenantId, productId, locationId])
  @@map("stock_reservations")
}

model StockSnapshot {
  id          String   @id @default(uuid())
  tenantId   String @map("tenant_id")
  locationId String @map("location_id")
  productId  String @map("product_id")
  reserved    Float
  available   Float
  snapshotAt DateTime @default(now()) @map("snapshot_at")
  inTransit   Float
  onHand      Float

  @@index([tenantId, productId])
  @@map("stock_snapshots")
}

model Store {
  id                   String                 @id @default(uuid())
  tenantId            String @map("tenant_id")
  locationId          String @map("location_id")
  name                 String
  code                 String
  type                 String
  status               String                 @default("active")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  managerId           String? @map("manager_id")
  email                String?
  inventoryPoolId    String? @map("inventory_pool_id")
  operatingHours      Json? @map("operating_hours")
  phone                String?
  settings             Json?
  timezone             String?                @default("Asia/Jakarta")
  country              String?
  currency             String?
  posDevices          PosDevice[]
  retailOrders        RetailOrder[]
  retailShifts        RetailShift[]
  inventoryPool      InventoryPool?       @relation(fields: [inventoryPoolId], references: [id])
  location            Location              @relation(fields: [locationId], references: [id])
  employee            Employee?             @relation(fields: [managerId], references: [id])
  company            Company              @relation(fields: [tenantId], references: [id])
  ecommerceConnectors EcommerceConnector[] @relation("EcommerceBranchLinks")

  @@unique([tenantId, code])
  @@index([locationId])
  @@index([status])
  @@index([tenantId])
  @@map("stores")
}

model SupplierBranch {
  id                       String                     @id @default(uuid())
  tenantId                String @map("tenant_id")
  supplierId              String @map("supplier_id")
  branchCode              String @map("branch_code")
  branchName              String @map("branch_name")
  location                 String
  leadTimeDays           Int                        @default(0) @map("lead_time_days")
  localRating             Int                        @default(0) @map("local_rating")
  riskTier                String                     @default("LOW") @map("risk_tier")
  active                   Boolean                    @default(true)
  createdAt               DateTime                   @default(now()) @map("created_at")
  updatedAt               DateTime @default(now()) @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")
  contactEmail            String? @map("contact_email")
  contactPerson           String? @map("contact_person")
  contactPhone            String? @map("contact_phone")
  fullAddress             String? @map("full_address")
  procurementDraftPos    ProcurementDraftPo[]
  procurementFinalPos    ProcurementFinalPo[]
  procurementRatingLogs  ProcurementRatingLog[]
  procurementReceipts     ProcurementReceipt[]
  procurementRequisitions ProcurementRequisition[]
