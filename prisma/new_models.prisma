
// ============================================================
// INVENTORY: Extended Models
// ============================================================

model InventoryAdjustment {
  id              String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  itemId          String   @map("item_id")
  locationCode    String   @map("location_code")
  departmentCode  String?  @map("department_code")
  requestedDelta  Float    @map("requested_delta")
  reason          String
  status          String   @default("PENDING_APPROVAL") // PENDING_APPROVAL, APPROVED, REJECTED
  requestedBy     String   @map("requested_by")
  approvedBy      String?  @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  company         Company  @relation(fields: [tenantId], references: [id])

  @@map("inventory_adjustments")
  @@index([tenantId])
}

model InventoryAuditCycle {
  id              String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  locationCode    String   @map("location_code")
  departmentCode  String?  @map("department_code")
  scope           String   // LOCATION, DEPARTMENT, ITEM
  status          String   @default("OPEN") // OPEN, COMPLETED
  expectedValue   Float?   @map("expected_value")
  countedValue    Float?   @map("counted_value")
  varianceValue   Float?   @map("variance_value")
  openedBy        String   @map("opened_by")
  closedBy        String?  @map("closed_by")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  company         Company  @relation(fields: [tenantId], references: [id])

  @@map("inventory_audit_cycles")
  @@index([tenantId])
}

model InventoryAlert {
  id              String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  type            String   // LOW_STOCK, EXPIRY_WARNING, ADJUSTMENT_REQUIRES_APPROVAL
  severity        String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  status          String   @default("OPEN") // OPEN, ACKNOWLEDGED, RESOLVED
  entityId        String   @map("entity_id")
  message         String
  acknowledged    Boolean  @default(false)
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  company         Company  @relation(fields: [tenantId], references: [id])

  @@map("inventory_alerts")
  @@index([tenantId])
}

model InventoryIntegrationEvent {
  id              String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  target          String   // FINANCE, PROCUREMENT, SALES, PAYMENT, HR, IT
  status          String   @default("SYNCED") // PENDING, SYNCED, FAILED
  eventType       String   @map("event_type")
  entityId        String   @map("entity_id")
  detail          String
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  company         Company  @relation(fields: [tenantId], references: [id])

  @@map("inventory_integration_events")
  @@index([tenantId])
}

// ============================================================
// MARKETING: Advanced Marketing Suite
// ============================================================

model MarketingCampaign {
  id             String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name           String
  objective      String   // AWARENESS, LEAD_GEN, CONVERSION, RETENTION
  channelMix     String[] @map("channel_mix")
  ownerId        String   @map("owner_id")
  ownerName      String   @map("owner_name")
  budget         Decimal  @db.Decimal(15, 2)
  currency       String   @default("USD")
  status         String   @default("DRAFT") // DRAFT, SCHEDULED, ACTIVE, COMPLETED, PAUSED
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  audience       String
  aiRecommendation String? @map("ai_recommendation")
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  company        Company    @relation(fields: [tenantId], references: [id])
  executions     MarketingExecutionRun[]
  attributions   MarketingAttribution[]

  @@map("marketing_campaigns")
  @@index([tenantId])
}

model MarketingExecutionRun {
  id             String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  campaignId     String   @map("campaign_id")
  channel        String   // EMAIL, WHATSAPP, GOOGLE_ADS, META_ADS, LANDING_PAGE, WEBINAR, EVENT
  scheduledAt    DateTime @map("scheduled_at")
  status         String   @default("SCHEDULED") // SCHEDULED, RUNNING, COMPLETED, FAILED
  leadsGenerated Int      @default(0) @map("leads_generated")
  spend          Decimal  @default(0) @db.Decimal(15, 2)
  notes          String?
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  company        Company    @relation(fields: [tenantId], references: [id])
  campaign       MarketingCampaign @relation(fields: [campaignId], references: [id])

  @@map("marketing_executions")
  @@index([tenantId])
  @@index([campaignId])
}

model MarketingLead {
  id                  String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  campaignId          String?  @map("campaign_id")
  source              String   // LANDING_PAGE, EMBEDDED_FORM, CHATBOT, WEBINAR, META_LEAD_ADS, GOOGLE_ADS, PARTNER_API
  companyName         String   @map("company_name")
  contactName         String   @map("contact_name")
  email               String?
  phone               String?
  country             String?
  industry            String?
  employeeBand        String?  @map("employee_band")
  dedupKey            String   @map("dedup_key")
  score               Int      @default(0)
  intent              String   @default("LOW") // LOW, MEDIUM, HIGH
  status              String   @default("SCORED") // CAPTURED, SCORED, QUALIFIED, HANDOFF_READY, HANDOFF_SENT
  qualificationReason String?  @map("qualification_reason")
  salesHandoffId      String?  @map("sales_handoff_id")
  
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  company             Company  @relation(fields: [tenantId], references: [id])
  attributions        MarketingAttribution[]

  @@map("marketing_leads")
  @@unique([tenantId, dedupKey])
  @@index([tenantId])
  @@index([status])
}

model MarketingNurtureWorkflow {
  id             String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name           String
  trigger        String   // LEAD_CAPTURED, STATUS_CHANGED, FORM_SUBMITTED
  status         String   @default("DRAFT") // DRAFT, ACTIVE, PAUSED
  steps          Json     // List of workflow steps
  aiSuggestion   String?  @map("ai_suggestion")
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  company        Company  @relation(fields: [tenantId], references: [id])

  @@map("marketing_workflows")
  @@index([tenantId])
}

model MarketingConnectedAccount {
  id             String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  provider       String   // GOOGLE, META, MAILCHIMP, HUBSPOT
  accountName    String   @map("account_name")
  status         String   @default("CONNECTED") // CONNECTED, DISCONNECTED, ERROR
  tokenExpiresAt DateTime @map("token_expires_at")
  scopes         String[]
  lastSyncAt     DateTime @map("last_sync_at")
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  company        Company  @relation(fields: [tenantId], references: [id])

  @@map("marketing_accounts")
  @@index([tenantId])
}

model MarketingAttribution {
  id                String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  campaignId        String   @map("campaign_id")
  leadId            String   @map("lead_id")
  opportunityId     String?  @map("opportunity_id")
  revenueAttributed Decimal  @map("revenue_attributed") @db.Decimal(15, 2)
  spend             Decimal  @db.Decimal(15, 2)
  roiPercent        Decimal  @map("roi_percent") @db.Decimal(10, 2)
  
  createdAt         DateTime @default(now()) @map("created_at")

  // Relations
  company           Company  @relation(fields: [tenantId], references: [id])
  campaign          MarketingCampaign @relation(fields: [campaignId], references: [id])
  lead              MarketingLead @relation(fields: [leadId], references: [id])

  @@map("marketing_attribution")
  @@index([tenantId])
  @@index([campaignId])
  @@index([leadId])
}

model MarketingAlert {
  id             String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  type           String   // TOKEN_EXPIRY, CAMPAIGN_FAILURE, HANDOFF_DELAY
  severity       String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  entityType     String   @map("entity_type") // CAMPAIGN, ACCOUNT, LEAD
  entityId       String   @map("entity_id")
  message        String
  acknowledged   Boolean  @default(false)
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  company        Company  @relation(fields: [tenantId], references: [id])

  @@map("marketing_alerts")
  @@index([tenantId])
}

model MarketingAuditEvent {
  id             String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  actorId        String   @map("actor_id")
  action         String
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  detail         String   @db.Text
  
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  company        Company  @relation(fields: [tenantId], references: [id])

  @@map("marketing_audit_events")
  @@index([tenantId])
}
