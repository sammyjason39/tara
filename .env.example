# ==============================================================================
# TARA HR System — Environment Variables
# Copy this file to .env and adjust values for your deployment.
#
# Usage:
#   cp .env.example .env
#   docker compose up --build
# ==============================================================================

# --- Database ---
DB_PASSWORD=your-db-password-here
DB_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend (internal Docker network only; public API via nginx /api/ on port 80) ---
BACKEND_PORT=3001

# --- Auth & CORS ---
#   ssh -L 5432:127.0.0.1:5432 user@your-server
JWT_SECRET=your-jwt-secret-min-32-characters
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,https://your-domain.example.com

# --- Frontend ---
FRONTEND_PORT=80
VITE_API_URL=https://your-domain.example.com

# --- Hermes (DISABLED — use TARA AI Assistant instead) ---
HERMES_ENABLED=false
HERMES_API_KEY=your-hermes-api-key-here

# --- TARA AI Assistant (OpenRouter / OpenAI-compatible) ---
AI_API_KEY=your-openrouter-api-key-here
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=your-model-id-here
AI_HR_ESCALATION_EMAIL=hr@your-company.example.com

# --- WhatsApp Agent (Kapso) ---
KAPSO_API_KEY=your-kapso-api-key-here
KAPSO_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
KAPSO_BUSINESS_ACCOUNT_ID=your-whatsapp-business-account-id
KAPSO_CONFIG_ID=your-kapso-config-uuid
KAPSO_BUSINESS_NUMBER=+62xxxxxxxxxx
KAPSO_WEBHOOK_SECRET=your-kapso-webhook-secret-here

# --- Attendance selfie photos (stored on backend disk) ---
ATTENDANCE_PHOTO_DIR=/var/data/tara/attendance
