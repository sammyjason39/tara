# ==============================================================================
# TARA HR System — Environment Variables
# Copy this file to .env and adjust values for your deployment.
#
# Usage:
#   cp .env.example .env
#   docker compose up --build
# ==============================================================================

# --- Database ---
DB_PASSWORD=tara_secret_2024
DB_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend (internal Docker network only; public API via nginx /api/ on port 80) ---
BACKEND_PORT=3001

# --- Database (localhost on VPS only — use SSH tunnel for remote access) ---
#   ssh -L 5432:127.0.0.1:5432 ubuntu@<server>
JWT_SECRET=change-this-to-a-long-random-string-in-production
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,https://tara.ralali.io,http://tara.ralali.io

# --- Frontend ---
FRONTEND_PORT=80
# Production: use domain (frontend calls /api/ via nginx proxy)
VITE_API_URL=https://tara.ralali.io

# --- Hermes (DISABLED — use TARA AI Assistant instead) ---
HERMES_ENABLED=false
HERMES_API_KEY=

# --- TARA AI Assistant (OpenRouter / OpenAI-compatible) ---
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=deepseek-v4-flash
# HR escalation contact for AI (default: Ahmad Yani)
AI_HR_ESCALATION_EMAIL=ahmad.yani@ralali.com

# --- WhatsApp Agent (Kapso) ---
# Kapso project API key (from Kapso Dashboard → Integrations → API keys)
KAPSO_API_KEY=
# WhatsApp phone number ID connected in Kapso
KAPSO_PHONE_NUMBER_ID=1177690982091942
# WhatsApp Business Account ID
KAPSO_BUSINESS_ACCOUNT_ID=1531978955225901
# Kapso config ID
KAPSO_CONFIG_ID=014dc306-766f-43a3-b088-5efc73518b58
# Business display number (E.164)
KAPSO_BUSINESS_NUMBER=+6285196416317
# Webhook signing secret (set same value in Kapso webhook config)
KAPSO_WEBHOOK_SECRET=
