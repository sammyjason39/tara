# ==============================================================================
# TARA HR System — Environment Variables
# Copy this file to .env and adjust values for your deployment.
#
# Usage:
#   cp .env.example .env
#   docker compose up --build
# ==============================================================================

# --- Database ---
DB_PASSWORD=tara_secret_2024
DB_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend (internal only — public API via nginx /api/ on port 80) ---
# BACKEND_PORT is not published; kept for documentation only
BACKEND_PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-in-production
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# --- Frontend ---
FRONTEND_PORT=80
VITE_API_URL=http://localhost:3001

# --- Hermes (DISABLED — use TARA AI Assistant instead) ---
HERMES_ENABLED=false
HERMES_API_KEY=

# --- TARA AI Assistant (Tokease / OpenAI-compatible) ---
AI_API_KEY=
AI_BASE_URL=https://tokease.com/v1
AI_MODEL=qwen3.7-plus

# --- WhatsApp Agent (Kapso) ---
# Kapso project API key (from Kapso Dashboard → Integrations → API keys)
KAPSO_API_KEY=
# WhatsApp phone number ID connected in Kapso
KAPSO_PHONE_NUMBER_ID=597907523413541
# WhatsApp Business Account ID
KAPSO_BUSINESS_ACCOUNT_ID=2102230076919824
# Kapso config ID
KAPSO_CONFIG_ID=31b31160-36d4-4468-92b6-2458fa6b949e
# Webhook signing secret (set same value in Kapso webhook config)
KAPSO_WEBHOOK_SECRET=
