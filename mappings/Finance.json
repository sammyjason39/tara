{
  "module": "Finance & Core Services",
  "name": "Zenvix Financial Ecosystem",
  "purpose": "Integrated money control, secure comms, and risk governance.",
  "lastUpdated": "2026-05-22",
  "backend": {
    "path": "backend/src/core/finance/",
    "mainService": "finance.service.ts",
    "keyServices": [
      {
        "name": "LedgerPostingService",
        "file": "services/ledger-posting.service.ts",
        "purpose": "Journal entry creation and posting with hash chain",
        "keyMethods": ["processEvent", "createJournalEntry", "postJournal"]
      },
      {
        "name": "JournalReversalService",
        "file": "services/journal-reversal.service.ts",
        "purpose": "Journal reversal with double-reversal prevention",
        "keyMethods": ["reverseJournal"],
        "bugFixes": ["BUG-4: Double-reversal check at line 45"]
      },
      {
        "name": "FiscalPeriodService",
        "file": "services/fiscal-period.service.ts",
        "purpose": "Period lifecycle management (OPEN → SOFT_LOCK → HARD_LOCK → CLOSED)",
        "keyMethods": ["validateTransition", "lockPeriod"],
        "knownIssues": ["BUG-5: No auto-voiding of DRAFT journals on HARD_LOCK"]
      },
      {
        "name": "ARBillService",
        "file": "services/ar-bill.service.ts",
        "purpose": "Accounts receivable management",
        "keyMethods": ["createInvoice", "issueInvoice", "recordPayment"],
        "knownIssues": ["BUG-3: No automated detection for orphaned entries"]
      },
      {
        "name": "APBillService",
        "file": "services/ap-bill.service.ts",
        "purpose": "Accounts payable management",
        "keyMethods": ["createBill", "recordPayment"]
      },
      {
        "name": "HashingService",
        "file": "utils/hashing.service.ts",
        "purpose": "Cryptographic hash chain for ledger integrity",
        "keyMethods": ["generateJournalHash"],
        "knownIssues": ["BUG-6: Need to verify MOCK-HASH detection"]
      },
      {
        "name": "JournalValidationService",
        "file": "services/journal-validation.service.ts",
        "purpose": "Journal entry validation",
        "keyMethods": ["check"],
        "bugFixes": ["BUG-7: BALANCE_TOLERANCE = 0 at line 9"]
      }
    ],
    "controllers": [
      "finance.controller.ts",
      "financial-dashboard.controller.ts",
      "controllers/ar.controller.ts",
      "controllers/ap.controller.ts"
    ],
    "repositories": [
      "repositories/journal-entry.repository.ts",
      "repositories/fiscal-period.repository.ts",
      "repositories/ar-invoice.repository.ts"
    ]
  },
  "frontend": {
    "path": "src/pages/core/finance/",
    "pages": [
      "MoneyDesk.tsx",
      "Ledger.tsx",
      "ARInvoices.tsx",
      "APBills.tsx",
      "TreasuryMap.tsx",
      "FixedAssets.tsx"
    ],
    "services": [
      "src/core/services/finance/ledger.service.ts",
      "src/core/services/finance/ar.service.ts",
      "src/core/services/finance/ap.service.ts"
    ]
  },
  "database": {
    "tables": [
      "finance_journal_entries",
      "finance_journal_lines",
      "finance_journal_reversals",
      "finance_fiscal_periods",
      "finance_chart_of_accounts",
      "finance_ar_invoices",
      "finance_ar_payments",
      "finance_ar_credit_memos",
      "finance_bank_statements",
      "finance_bank_transactions"
    ]
  },
  "subModules": [
    {
      "name": "Payment",
      "backend": "backend/src/core/payment/",
      "frontend": "src/pages/core/payment/",
      "features": ["Transaction Flow", "Routing Policies", "Provider Health", "Refunds", "Disputes", "Settlement"],
      "knownIssues": ["BUG-11: No offline payment matrix enforcement at backend"]
    },
    {
      "name": "Chat",
      "backend": "backend/src/shared/comms/chat.service.ts",
      "frontend": "src/pages/core/comms/Chat.tsx",
      "features": ["Direct Messaging", "Group/Dept/Role Rooms", "Message Status", "Pagination", "Unread Tracking"]
    },
    {
      "name": "Mail",
      "backend": "backend/src/shared/comms/mail.service.ts",
      "frontend": "src/pages/core/comms/Mail.tsx",
      "features": ["Intel Threading", "@zenvix.internal Accounts", "Folders (Inbox/Sent/Starred)", "Real-time Notification"]
    },
    {
      "name": "Notification",
      "backend": "backend/src/shared/comms/notification.service.ts",
      "frontend": "src/components/shared/NotificationCenter.tsx",
      "features": ["Global Broadcast", "Integrated Unread Sync", "Actionable Deep-links"]
    }
  ],
  "integrations": [
    {
      "module": "HR",
      "trigger": "Payroll run completion",
      "action": "Create journal entry for payroll expense",
      "flow": "HRPayrollService → LedgerPostingService"
    },
    {
      "module": "Inventory",
      "trigger": "Stock movement",
      "action": "Create journal entry for inventory valuation",
      "flow": "InventorySubledgerService → LedgerPostingService"
    },
    {
      "module": "Retail",
      "trigger": "Order completion",
      "action": "Create AR invoice",
      "flow": "RetailService → ARBillService"
    },
    {
      "module": "Procurement",
      "trigger": "Goods receipt",
      "action": "Create AP bill",
      "flow": "ProcurementService → APBillService"
    }
  ],
  "security": "Immutable Audit Store + Cryptographic Hash Chain + Secure Enclaves"
}

