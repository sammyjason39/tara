{
  "module": "Inventory",
  "name": "Global Inventory & Stock",
  "purpose": "Stock control, receiving, and governance across physical/logical sites.",
  "lastUpdated": "2026-05-22",
  "backend": {
    "path": "backend/src/core/inventory/",
    "mainService": "inventory.service.ts",
    "keyServices": [
      {
        "name": "InventoryService",
        "file": "inventory.service.ts",
        "purpose": "Core inventory operations including stock transfers",
        "keyMethods": ["receiveTransfer", "shipTransfer", "reserveStock", "adjustStock"],
        "bugFixes": ["BUG-1: receiveTransfer fix at line 435 - uses transfer.to_location_id as fromLocationId"]
      },
      {
        "name": "ItemImageService",
        "file": "item-image.service.ts",
        "purpose": "Item image management",
        "keyMethods": ["uploadImage", "getImage"]
      },
      {
        "name": "SKUGeneratorService",
        "file": "sku-generator.service.ts",
        "purpose": "Automatic SKU generation",
        "keyMethods": ["generateSKU"]
      },
      {
        "name": "LabelTemplateService",
        "file": "label-template.service.ts",
        "purpose": "Label printing templates",
        "keyMethods": ["generateLabel"]
      }
    ],
    "controllers": [
      {
        "name": "InventoryController",
        "file": "inventory.controller.ts",
        "knownIssues": ["BUG-8: Check for wildcard route deprecation @Get('images/*')"]
      },
      {
        "name": "StockTransferController",
        "file": "controllers/stock-transfer.controller.ts"
      },
      {
        "name": "StockAdjustmentController",
        "file": "controllers/stock-adjustment.controller.ts"
      }
    ],
    "repositories": [
      "repositories/item-master.repository.ts",
      "repositories/stock-level.repository.ts",
      "repositories/stock-movement.repository.ts",
      "repositories/stock-reservation.repository.ts"
    ]
  },
  "frontend": {
    "path": "src/pages/core/inventory/",
    "pages": [
      "StockController.tsx",
      "ReceivingDock.tsx",
      "AdjustmentDesk.tsx",
      "TransferHub.tsx",
      "ItemMaster.tsx"
    ],
    "services": [
      "src/core/services/inventory/stock.service.ts",
      "src/core/services/inventory/transfer.service.ts"
    ]
  },
  "database": {
    "tables": [
      "item_masters",
      "stock_levels",
      "stock_movements",
      "stock_reservations",
      "inventory_transfers",
      "inventory_adjustments",
      "locations",
      "item_images"
    ]
  },
  "navigation": [
    {
      "label": "Stock Controller",
      "path": "/core/inventory/dashboard",
      "trigger": "Run Scan",
      "purpose": "Identify stock-outs, anomalies, and expiry risks.",
      "workflow": {
        "steps": ["Automated Scan", "Severity Scoring", "Action Queue Update"],
        "outputs": ["Low Stock Alerts", "Expiry Warnings"]
      }
    },
    {
      "label": "Receiving Dock",
      "path": "/core/inventory/receiving",
      "trigger": "Confirm Receipt",
      "purpose": "Formally accept incoming shipments into the system.",
      "workflow": {
        "steps": ["PO Matching", "Physical Count", "Manager Sign-off"],
        "outputs": ["Stock Qty Increase", "Finance Sync"]
      }
    },
    {
      "label": "Adjustment Desk",
      "path": "/core/inventory/adjustments",
      "trigger": "Create Adjustment",
      "purpose": "Fix stock discrepancies and log damaged/lost items.",
      "workflow": {
        "steps": ["Reason Entry", "Quantity Correction", "Finance Approval"],
        "outputs": ["Adjusted Balances", "Immutable Audit Log"]
      }
    },
    {
      "label": "Transfer Hub",
      "path": "/core/inventory/transfers",
      "trigger": "Create Transfer",
      "purpose": "Move stock between locations.",
      "workflow": {
        "steps": ["REQUESTED → PICKED → SHIPPED → IN_TRANSIT → RECEIVED"],
        "outputs": ["Stock Movement Records", "Location Balance Updates"]
      }
    }
  ],
  "integrations": [
    {
      "module": "Retail",
      "trigger": "Order creation",
      "action": "Reserve stock",
      "flow": "RetailService → InventoryService.reserveStock()"
    },
    {
      "module": "Finance",
      "trigger": "Stock movement",
      "action": "Create journal entry for inventory valuation",
      "flow": "InventorySubledgerService → LedgerPostingService"
    },
    {
      "module": "Procurement",
      "trigger": "Goods receipt",
      "action": "Increase stock levels",
      "flow": "ProcurementService → InventoryService.receiveStock()"
    }
  ]
}
