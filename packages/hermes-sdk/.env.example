# ==============================================================================
# Hermes SDK — Environment Variables
# Copy to .env on the Hermes VPS
# ==============================================================================

# --- Connection Method ---
# Choose ONE: direct HTTP or SSH tunnel

# Option A: Direct HTTP (if Hermes VPS can reach TARA's port directly)
# TARA_URL=http://your-tara-host:3081

# Option B: SSH Tunnel (if only SSH port 22 is reachable)
TARA_SSH_HOST=your-tara-server-ip-or-hostname
TARA_SSH_PORT=22
TARA_SSH_USER=your-ssh-user
TARA_SSH_PASSWORD=your-ssh-password-here
# Or use key-based auth instead of password:
# TARA_SSH_KEY=/path/to/your/private-key
TARA_REMOTE_PORT=3081

# --- Hermes Authentication ---
# Must match HERMES_API_KEY configured on the TARA backend
HERMES_API_KEY=your-hermes-api-key-here

# --- Agent Identity ---
HERMES_AGENT_ID=your-hermes-agent-id
