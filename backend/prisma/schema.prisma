model accounting_periods {
  id         String    @id @default(uuid())
  tenant_id  String
  company_id String?
  name       String
  start_date DateTime
  end_date   DateTime
  status     String
  closed_at  DateTime?
  closed_by  String?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  // @@map("accounting_periods") - standardized
  tenants    tenants   @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, name])
  @@index([status])
  @@index([tenant_id])
  @@index([company_id])
}

model admin_audit_events {
  id          String   @id @default(uuid())
  tenant_id   String
  company_id  String?
  action      String
  entity_type String
  entity_id   String
  actor_id    String
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  // @@map("admin_audit_events") - standardized
  tenants tenants @relation(fields: [tenant_id], references: [id])
}

model admin_module_statuses {
  id         String   @id @default(uuid())
  tenant_id  String
  company_id String?
  module_key String
  enabled    Boolean  @default(true)
  updated_by String
  updated_at DateTime @default(now())
  // @@map("admin_module_statuses") - standardized
  tenants    tenants  @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, module_key])
}

model admin_requests {
  id           String   @id @default(uuid())
  tenant_id    String
  company_id   String?
  type         String
  title        String
  detail       String?
  status       String   @default("open")
  requested_by String
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())
  resolved_by  String?

  // @@map("admin_requests") - standardized
  tenants tenants @relation(fields: [tenant_id], references: [id])
}

model agentic_events {
  id              String     @id @default(uuid())
  tenant_id       String
  company_id      String?
  event_type      String
  entity_id       String
  entity_type     String
  payload         Json
  status          String     @default("PENDING")
  processed_at    DateTime?
  error_msg       String?
  created_at      DateTime   @default(now())
  correlation_id  String?
  source_event_id String?
  companies       companies? @relation(fields: [company_id], references: [id])
  updated_at      DateTime   @default(now())
  // @@map("agentic_events") - standardized
  tenants         tenants    @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, entity_id])
  @@index([tenant_id, event_type, status])
}

model asset_depreciation_entries {
  id               String   @id @default(uuid())
  tenant_id        String
  company_id       String?
  asset_id         String
  period           String
  date             DateTime
  depreciation_exp Decimal  @db.Decimal(15, 2)
  accumulated_dep  Decimal  @db.Decimal(15, 2)
  carrying_value   Decimal  @db.Decimal(15, 2)
  journal_ref      String?
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now())
  // @@map("asset_depreciation_entries") - standardized
  tenants          tenants  @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, asset_id])
}

model asset_events {
  id          String   @id @default(uuid())
  tenant_id   String
  company_id  String?
  asset_id    String
  type        String
  description String
  date        DateTime
  recorded_by String
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
  // @@map("asset_events") - standardized
  tenants     tenants  @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, asset_id])
}

model audit_hash_anchors {
  id           String     @id @default(uuid())
  tenant_id    String
  company_id   String?
  anchor_hash  String
  anchored_at  DateTime   @default(now())
  record_count Int
  companies    companies? @relation(fields: [company_id], references: [id])
  updated_at   DateTime   @default(now())
  // @@map("audit_hash_anchors") - standardized
  tenants      tenants    @relation(fields: [tenant_id], references: [id])

  @@index([anchored_at])
  @@index([tenant_id])
  @@index([company_id])
}

model audit_logs {
  id                 String     @id @default(uuid())
  tenant_id          String
  company_id         String?
  module             String
  action             String
  entity_type        String
  entity_id          String
  user_id            String
  changes            Json?
  metadata           Json?
  created_at         DateTime   @default(now())
  ip_address         String?
  severity           String     @default("INFO")
  user_agent         String?
  hash_chain         String?
  source_module      String?
  after_state        Json?
  before_state       Json?
  correlation_id     String?
  idempotency_key    String?
  original_hash      String?
  previous_hash      String?
  recomputed_hash    String?
  status             String     @default("NORMAL")
  event_reference_id String?
  companies          companies? @relation(fields: [company_id], references: [id])
  updated_at         DateTime   @default(now())
  // @@map("audit_logs") - standardized
  tenants            tenants    @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, idempotency_key])
  @@index([created_at])
  @@index([module])
  @@index([tenant_id, entity_type, entity_id])
  @@index([tenant_id])
  @@index([company_id])
  @@index([tenant_id, source_module])
  @@index([user_id])
}

model bulletin_categories {
  id         String     @id @default(uuid())
  tenant_id  String
  company_id String?
  name       String
  code       String
  color      String?
  created_at DateTime   @default(now())
  updated_at DateTime   @default(now())
  companies  companies? @relation(fields: [company_id], references: [id])
  // @@map("bulletin_categories") - standardized
  tenants    tenants    @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, code])
}

model bulletin_comments {
  id             String         @id @default(uuid())
  post_id        String
  tenant_id      String
  company_id     String?
  author_id      String
  body           String
  created_at     DateTime       @default(now())
  deleted_at     DateTime?
  retail_id      String?
  bulletin_posts bulletin_posts @relation(fields: [post_id], references: [id], onDelete: Cascade)
  companies      companies?     @relation(fields: [company_id], references: [id])
  updated_at     DateTime       @default(now())
  // @@map("bulletin_comments") - standardized
  tenants        tenants        @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@index([company_id])
}

model bulletin_posts {
  id                 String               @id @default(uuid())
  tenant_id          String
  company_id         String?
  author_id          String
  title              String
  body               String
  category           String               @default("general")
  attachments        Json?
  status             String               @default("published")
  is_pinned          Boolean              @default(false)
  pin_order          Int?
  scope_type         String               @default("company")
  scope_id           String?
  publish_at         DateTime?
  expires_at         DateTime?
  view_count         Int                  @default(0)
  created_at         DateTime             @default(now())
  updated_at         DateTime             @default(now())
  deleted_at         DateTime?
  retail_id          String?
  bulletin_comments  bulletin_comments[]
  companies          companies?           @relation(fields: [company_id], references: [id])
  bulletin_reactions bulletin_reactions[]
  bulletin_reads     bulletin_reads[]
  // @@map("bulletin_posts") - standardized
  tenants            tenants              @relation(fields: [tenant_id], references: [id])

  @@index([status])
  @@index([tenant_id])
  @@index([company_id])
}

model bulletin_reactions {
  id             String         @id @default(uuid())
  post_id        String
  user_id        String
  created_at     DateTime       @default(now())
  tenant_id      String
  company_id     String?
  type           String         @default("LIKE")
  bulletin_posts bulletin_posts @relation(fields: [post_id], references: [id], onDelete: Cascade)
  companies      companies?     @relation(fields: [company_id], references: [id])
  updated_at     DateTime       @default(now())
  // @@map("bulletin_reactions") - standardized
  tenants        tenants        @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, post_id, user_id, type])
  @@index([tenant_id])
  @@index([company_id])
}

model bulletin_reads {
  id             String         @id @default(uuid())
  post_id        String
  user_id        String
  read_at        DateTime       @default(now())
  bulletin_posts bulletin_posts @relation(fields: [post_id], references: [id], onDelete: Cascade)
  updated_at     DateTime       @default(now())
  // @@map("bulletin_reads") - standardized

  @@unique([post_id, user_id])
}

model candidates {
  id               String           @id @default(uuid())
  tenant_id        String
  company_id       String?
  first_name       String
  last_name        String
  email            String
  phone            String?
  requisition_id   String
  source           String
  status           String           @default("applied")
  resume_url       String?
  metadata         Json?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @default(now())
  deleted_at       DateTime?
  retail_id        String?
  job_requisitions job_requisitions @relation(fields: [requisition_id], references: [id])
  companies        companies?       @relation(fields: [company_id], references: [id])
  interviews       interviews[]
  // @@map("candidates") - standardized
  tenants          tenants          @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@index([company_id])
}

model capex_budgets {
  id               String   @id @default(uuid())
  tenant_id        String
  company_id       String?
  department_id    String
  period           String
  allocated_budget Decimal  @db.Decimal(15, 2)
  committed_budget Decimal  @default(0) @db.Decimal(15, 2)
  available_budget Decimal  @db.Decimal(15, 2)
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now())

  departments departments @relation(fields: [department_id], references: [id])
  // @@map("capex_budgets") - standardized
  tenants     tenants     @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, department_id, period])
  @@index([tenant_id])
  @@index([company_id])
}

model capex_requests {
  id                     String         @id @default(uuid())
  tenant_id              String
  company_id             String?
  asset_description      String
  requested_amount       Decimal        @db.Decimal(15, 2)
  departments            String
  project_code           String?
  requested_by           String
