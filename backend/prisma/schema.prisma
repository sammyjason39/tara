generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// TARA HR System - HR-Only Schema
// ============================================================================
// This schema contains only HR-related models for the TARA system.
// All non-HR models (Finance, Sales, Inventory, Marketing, Procurement, IT,
// Administration, Retail, Cafe) have been removed as part of the HR-focused
// transformation.
// ============================================================================

// Core HR Models
model Employee {
  id                   String   @id @default(uuid())
  employee_code        String   @unique
  full_name            String
  email                String   @unique
  phone                String?
  password_hash        String?
  pin_hash             String?   // 6-digit PIN hash for attendance verification
  must_change_password Boolean  @default(false)
  password_changed_at  DateTime? // Set on first successful password change — stops force-change prompts
  pin_changed_at       DateTime? // Last PIN update — used for monthly rotation reminder
  department_id        String?
  role_id              String?
  supervisor_id        String?
  office_location_id   String?
  hire_date            DateTime
  employment_status    String   @default("active") // 'active', 'probation', 'on_leave', 'resigned', 'terminated'
  biometric_token_hash String?
  biometric_device_id  String?
  language_preference  String   @default("id")
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now())
  created_by           String?
  updated_by           String?

  // Relations
  department   Department?     @relation("EmployeeDepartment", fields: [department_id], references: [id])
  role         Role?           @relation("EmployeeRole", fields: [role_id], references: [id])
  supervisor   Employee?       @relation("EmployeeSupervisor", fields: [supervisor_id], references: [id])
  subordinates Employee[]      @relation("EmployeeSupervisor")
  office       OfficeLocation? @relation("EmployeeOffice", fields: [office_location_id], references: [id])

  attendance_records      Attendance[]
  leave_requests          LeaveRequest[]       @relation("EmployeeLeaveRequests")
  approved_leave_requests LeaveRequest[]       @relation("LeaveApprover")
  leave_balances          LeaveBalance[]
  notifications           Notification[]
  warning_letters         WarningLetter[]      @relation("WarningLetterRecipient")
  issued_warnings         WarningLetter[]      @relation("WarningLetterIssuer")
  weekly_checkins         WeeklyCheckin[]
  onboarding_status       OnboardingStatus[]
  aws_device_mapping      AWSDeviceMapping?
  event_bus_logs_actor    EventBusLog[]        @relation("EventBusLogActor")
  audit_logs_actor        AuditLog[]           @relation("AuditLogActor")
  offline_actions         OfflineActionQueue[]
  absence_records         AbsenceRecord[]      @relation()
  absence_reports         AbsenceRecord[]      @relation("AbsenceReporter")
  schedule_assignments    ScheduleAssignment[]
  loans                   Loan[]               @relation()
  approved_loans          Loan[]               @relation("LoanApprover")
  payslips                Payslip[]

  hermes_follow_ups   HermesFollowUp[] @relation("HermesFollowUpRecipient")

  // WhatsApp Integration
  whatsapp_number      String?
  whatsapp_opted_in    Boolean  @default(false)
  whatsapp_verified    Boolean  @default(false)
  whatsapp_verified_at DateTime?

  whatsapp_messages  WhatsAppMessageLog[] @relation("WhatsAppEmployee")
  whatsapp_sessions  WhatsAppSession[]    @relation("WhatsAppSessionEmployee")
  ai_agent_logs      AiAgentLog[]         @relation("AiAgentLogEmployee")
  ai_pending_actions AiPendingAction[]    @relation("AiPendingActionEmployee")

  created_employees Employee[] @relation("EmployeeCreator")
  updated_employees Employee[] @relation("EmployeeUpdater")
  creator           Employee?  @relation("EmployeeCreator", fields: [created_by], references: [id])
  updater           Employee?  @relation("EmployeeUpdater", fields: [updated_by], references: [id])

  @@index([department_id])
  @@index([role_id])
  @@index([supervisor_id])
  @@index([office_location_id])
  @@index([employment_status])
  @@index([email])
  @@map("employees")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  manager_id  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  // Relations
  employees Employee[] @relation("EmployeeDepartment")

  @@index([manager_id])
  @@map("departments")
}

model Role {
  id          String   @id @default(uuid())
  role_name   String   @unique
  permissions Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  // Relations
  employees Employee[] @relation("EmployeeRole")

  @@map("roles")
}

// Attendance Models
model Attendance {
  id                 String                                @id @default(uuid())
  employee_id        String
  attendance_date    DateTime                              @db.Date
  clock_in_time      DateTime?
  clock_in_location  Unsupported("geography(Point,4326)")? // PostGIS GEOGRAPHY type for GPS coordinates
  clock_in_source    String                                @default("phone") // 'phone' or 'aws'
  clock_out_time     DateTime?
  clock_out_location Unsupported("geography(Point,4326)")? // PostGIS GEOGRAPHY type for GPS coordinates
  clock_out_source   String                                @default("phone")
  is_tardy           Boolean                               @default(false)
  tardiness_minutes  Int                                   @default(0)
  office_location_id String?
  clock_in_photo_path  String?
  clock_out_photo_path String?
  override_reason    String?
  override_by        String?
  created_at         DateTime                              @default(now())
  updated_at         DateTime                              @default(now())

  // Relations
  employee        Employee        @relation(fields: [employee_id], references: [id])
  office_location OfficeLocation? @relation(fields: [office_location_id], references: [id])

  @@unique([employee_id, attendance_date])
  @@index([employee_id])
  @@index([attendance_date])
  @@index([is_tardy])
  @@index([employee_id, attendance_date])
  @@map("attendance")
}

// Leave Management Models
model LeaveRequest {
  id               String    @id @default(uuid())
  employee_id      String
  leave_type       String // 'annual', 'sick', 'emergency', 'unpaid', 'maternity', 'paternity'
  is_paid          Boolean   @default(true) // false for unpaid leave
  start_date       DateTime  @db.Date
  end_date         DateTime  @db.Date
  total_days       Decimal  @db.Decimal(6, 2)
  reason           String?
  status           String    @default("pending") // 'pending', 'approved', 'rejected', 'cancelled'
  submitted_at     DateTime  @default(now())
  approved_by      String?
  approved_at      DateTime?
  rejection_reason String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())

  // Relations
  employee Employee  @relation("EmployeeLeaveRequests", fields: [employee_id], references: [id])
  approver Employee? @relation("LeaveApprover", fields: [approved_by], references: [id])

  @@index([employee_id])
  @@index([status])
  @@index([start_date, end_date])
  @@index([approved_by])
  @@index([employee_id, status]) // Composite: filter employee's leaves by status (pending/approved)
  @@map("leave_requests")
}

model LeaveBalance {
  id                    String    @id @default(uuid())
  employee_id           String
  year                  Int
  total_entitlement     Decimal   @db.Decimal(8, 2)
  used_days             Decimal   @default(0) @db.Decimal(8, 2)
  remaining_days        Decimal   @db.Decimal(8, 2)
  carryover_days        Decimal   @default(0) @db.Decimal(8, 2)
  carryover_expiry_date DateTime? @db.Date
  last_calculated_at    DateTime  @default(now())
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now())

  // Relations
  employee Employee @relation(fields: [employee_id], references: [id])

  @@unique([employee_id, year])
  @@index([employee_id])
  @@index([year])
  @@map("leave_balances")
}

// Notification Models
model Notification {
  id                String    @id @default(uuid())
  recipient_id      String
  notification_type String // 'clock_confirmation', 'leave_approved', 'warning_letter', etc.
  visibility        String    @default("private") // 'private' or 'public'
  title             String
  content           String
  is_read           Boolean   @default(false)
  read_at           DateTime?
  metadata          Json?
  created_at        DateTime  @default(now())

  // Relations
  recipient Employee @relation(fields: [recipient_id], references: [id])

  @@index([recipient_id])
  @@index([notification_type])
  @@index([is_read])
  @@index([created_at])
  @@index([recipient_id, is_read]) // Composite: unread notifications per employee
  @@index([recipient_id, created_at(sort: Desc)]) // Composite: sorted notification feed per employee
  @@map("notifications")
}

// Warning Letter Models
model WarningLetter {
  id            String    @id @default(uuid())
  employee_id   String
  warning_level String // 'SP1', 'SP2', 'SP3'
  issue_date    DateTime  @db.Date
  reason        String
  issued_by     String
  expiry_date   DateTime? @db.Date
  status        String    @default("active") // 'active', 'expired', 'revoked'
  content       String
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now())

  // Relations
  employee Employee @relation("WarningLetterRecipient", fields: [employee_id], references: [id])
  issuer   Employee @relation("WarningLetterIssuer", fields: [issued_by], references: [id])

  @@index([employee_id])
  @@index([warning_level])
  @@index([status])
  @@index([employee_id, status]) // Composite: active warnings per employee
  @@map("warning_letters")
}

// Weekly Check-in Models
model WeeklyCheckin {
  id              String   @id @default(uuid())
  employee_id     String
  week_start_date DateTime @db.Date
  accomplishments String?
  challenges      String?
  next_week_goals String?
  submitted_at    DateTime @default(now())
  created_at      DateTime @default(now())

  // Relations
  employee Employee @relation(fields: [employee_id], references: [id])

  @@unique([employee_id, week_start_date])
  @@index([employee_id])
  @@index([week_start_date])
  @@map("weekly_checkins")
}

// Onboarding Models
model OnboardingStatus {
  id             String    @id @default(uuid())
  employee_id    String
  step_number    Int // 1-7
  step_name      String // 'Email Account', 'Welcome Kit', etc.
  status         String    @default("pending") // 'pending', 'in_progress', 'completed', 'failed'
  started_at     DateTime?
  completed_at   DateTime?
  failure_reason String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now())

  // Relations
  employee Employee @relation(fields: [employee_id], references: [id])

  @@unique([employee_id, step_number])
  @@index([employee_id])
  @@index([status])
  @@map("onboarding_status")
}

// System Configuration Models
model SystemSettings {
  id               String   @id @default(uuid())
  setting_key      String   @unique
  setting_value    Json
  setting_category String // 'attendance', 'leave', 'geofence', 'notification', etc.
  description      String?
  last_modified_by String?
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now())

  @@index([setting_category])
  @@index([setting_key])
  @@map("system_settings")
}

model AgentConfig {
  id                String    @id @default(uuid())
  agent_name        String    @unique // 'leave_request', 'absensi', 'clock_confirmation', etc.
  is_enabled        Boolean   @default(true)
  configuration     Json
  last_heartbeat_at DateTime?
  health_status     String    @default("unknown") // 'healthy', 'degraded', 'down', 'unknown'
  error_message     String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now())

  @@index([agent_name])
  @@index([is_enabled])
  @@map("agent_configs")
}

model OfficeLocation {
  id                     String   @id @default(uuid())
  location_name          String
  address                String?
  latitude               Decimal  @db.Decimal(10, 8)
  longitude              Decimal  @db.Decimal(11, 8)
  geofence_radius_meters Int
  is_active              Boolean  @default(true)
  created_at             DateTime @default(now())
  updated_at             DateTime @default(now())

  // Relations
  attendance_records Attendance[]
  employees          Employee[]   @relation("EmployeeOffice")

  @@index([is_active])
  @@map("office_locations")
}

model PublicHoliday {
  id           String   @id @default(uuid())
  holiday_date DateTime @unique @db.Date
  holiday_name String
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  @@index([holiday_date])
  @@index([is_active])
  @@map("public_holidays")
}

// AWS Integration Models
model AWSDeviceMapping {
  id               String   @id @default(uuid())
  aws_employee_id  String   @unique
  tara_employee_id String   @unique
  aws_device_id    String?
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now())

  // Relations
  employee Employee @relation(fields: [tara_employee_id], references: [id])

  @@index([tara_employee_id])
  @@index([is_active])
  @@map("aws_device_mappings")
}

// Event and Audit Models
model EventBusLog {
  id              String    @id @default(uuid())
  event_type      String
  event_version   String    @default("1.0")
  actor_id        String?
  actor_type      String? // 'employee', 'agent', 'system'
  entity_id       String?
  entity_type     String? // 'attendance', 'leave_request', 'employee', etc.
  event_payload   Json
  event_timestamp DateTime  @default(now())
  published_at    DateTime?
  delivery_status String    @default("pending") // 'pending', 'delivered', 'failed'
  retry_count     Int       @default(0)
  created_at      DateTime  @default(now())

  // Relations
  actor Employee? @relation("EventBusLogActor", fields: [actor_id], references: [id])

  @@index([event_type])
  @@index([event_timestamp])
  @@index([actor_id])
  @@index([entity_id, entity_type])
  @@index([delivery_status])
  @@index([event_type, event_timestamp]) // Composite: event replay/filtering by type within time range
  @@index([delivery_status, event_timestamp]) // Composite: retry queue processing (pending events by age)
  @@map("event_bus_logs")
}

model AuditLog {
  id                 String   @id @default(uuid())
  action_type        String // 'create', 'update', 'delete', 'approve', etc.
  actor_id           String?
  actor_role         String? // 'employee', 'hr_team', 'supervisor'
  target_entity_type String // 'employee', 'leave_request', 'warning_letter', etc.
  target_entity_id   String?
  action_context     String? // 'administrative', 'personal_employee'
  changes            Json?
  ip_address         String?
  user_agent         String?
  created_at         DateTime @default(now())

  // Relations
  actor Employee? @relation("AuditLogActor", fields: [actor_id], references: [id])

  @@index([action_type])
  @@index([actor_id])
  @@index([created_at])
  @@index([target_entity_type, target_entity_id])
  @@index([action_context])
  @@index([actor_id, created_at(sort: Desc)]) // Composite: user activity history sorted by recency
  @@map("audit_logs")
}

// Offline Support Models
model OfflineActionQueue {
  id               String    @id @default(uuid())
  employee_id      String
  action_type      String // 'clock_in', 'clock_out', 'leave_request', etc.
  action_payload   Json
  client_timestamp DateTime
  sync_status      String    @default("pending") // 'pending', 'synced', 'failed'
  synced_at        DateTime?
  sync_error       String?
  created_at       DateTime  @default(now())

  // Relations
  employee Employee @relation(fields: [employee_id], references: [id])

  @@index([employee_id])
  @@index([sync_status])
  @@index([created_at])
  @@map("offline_action_queue")
}

// ============================================================================
// TARA v2 — Extended Models (Payroll, Loans, Schedules, Absence Tracking)
// ============================================================================

// Company Holiday (separate from Public Holiday — company-specific days off)
model CompanyHoliday {
  id           String   @id @default(uuid())
  holiday_date DateTime @db.Date
  holiday_name String
  description  String?
  is_recurring Boolean  @default(false) // yearly recurring
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  @@unique([holiday_date])
  @@index([holiday_date])
  @@index([is_active])
  @@map("company_holidays")
}

// Absence Record — tracks unexcused absences (Alpha / No Info)
model AbsenceRecord {
  id           String   @id @default(uuid())
  employee_id  String
  absence_date DateTime @db.Date
  absence_type String   // 'no_info', 'unexcused', 'excused_late', 'half_day'
  reason       String?
  reported_by  String?  // HR who recorded this
  resolved     Boolean  @default(false)
  resolved_at  DateTime?
  resolution_note String?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  employee  Employee  @relation(fields: [employee_id], references: [id])
  reporter  Employee? @relation("AbsenceReporter", fields: [reported_by], references: [id])

  @@unique([employee_id, absence_date])
  @@index([employee_id])
  @@index([absence_date])
  @@index([absence_type])
  @@map("absence_records")
}

// Work Schedule — shift/schedule assignments
model WorkSchedule {
  id            String   @id @default(uuid())
  schedule_name String   // 'Shift Pagi', 'Shift Siang', 'Normal', etc.
  start_time    String   // "08:00" format
  end_time      String   // "17:00" format
  break_start   String?  // "12:00"
  break_end     String?  // "13:00"
  work_days     Json     // [1,2,3,4,5] = Mon-Fri
  daily_breaks  Json?    // e.g. { "5": { "break_start": "11:30", "break_end": "13:30" } }
  is_default    Boolean  @default(false)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())

  assignments ScheduleAssignment[]

  @@index([is_active])
  @@map("work_schedules")
}

// Schedule Assignment — which employee has which schedule
model ScheduleAssignment {
  id            String    @id @default(uuid())
  employee_id   String
  schedule_id   String
  effective_from DateTime @db.Date
  effective_to   DateTime? @db.Date  // null = ongoing
  assigned_by   String?
  created_at    DateTime  @default(now())

  employee Employee     @relation(fields: [employee_id], references: [id])
  schedule WorkSchedule @relation(fields: [schedule_id], references: [id])

  @@index([employee_id])
  @@index([schedule_id])
  @@index([effective_from])
  @@map("schedule_assignments")
}

// Loan / Kasbon (Employee Borrowing)
model Loan {
  id              String    @id @default(uuid())
  employee_id     String
  loan_type       String    // 'kasbon', 'salary_advance', 'emergency'
  amount          Decimal   @db.Decimal(15, 2)
  remaining_balance Decimal @db.Decimal(15, 2)
  installment_amount Decimal? @db.Decimal(15, 2) // monthly deduction
  installment_count Int?     // total installments
  paid_installments Int      @default(0)
  status          String    @default("pending") // 'pending', 'approved', 'active', 'paid_off', 'rejected'
  request_date    DateTime  @default(now())
  approved_by     String?
  approved_at     DateTime?
  reason          String?
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now())

  employee Employee  @relation(fields: [employee_id], references: [id])
  approver Employee? @relation("LoanApprover", fields: [approved_by], references: [id])
  repayments LoanRepayment[]

  @@index([employee_id])
  @@index([status])
  @@map("loans")
}

// Loan Repayment History
model LoanRepayment {
  id          String   @id @default(uuid())
  loan_id     String
  amount      Decimal  @db.Decimal(15, 2)
  payment_date DateTime @db.Date
  payment_method String @default("payroll_deduction") // 'payroll_deduction', 'manual', 'transfer'
  notes       String?
  created_at  DateTime @default(now())

  loan Loan @relation(fields: [loan_id], references: [id])

  @@index([loan_id])
  @@index([payment_date])
  @@map("loan_repayments")
}

// Payroll Period
model PayrollPeriod {
  id          String   @id @default(uuid())
  period_name String   // "Juni 2026", "2026-06"
  start_date  DateTime @db.Date
  end_date    DateTime @db.Date
  status      String   @default("draft") // 'draft', 'processing', 'finalized', 'paid'
  total_gross Decimal? @db.Decimal(15, 2)
  total_deductions Decimal? @db.Decimal(15, 2)
  total_net   Decimal? @db.Decimal(15, 2)
  processed_by String?
  processed_at DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  payslips Payslip[]

  @@unique([start_date, end_date])
  @@index([status])
  @@map("payroll_periods")
}

// Payslip (per employee per period)
model Payslip {
  id              String   @id @default(uuid())
  employee_id     String
  period_id       String
  base_salary     Decimal  @db.Decimal(15, 2)
  total_additions Decimal  @db.Decimal(15, 2) @default(0)
  total_deductions Decimal @db.Decimal(15, 2) @default(0)
  net_salary      Decimal  @db.Decimal(15, 2)
  status          String   @default("draft") // 'draft', 'finalized', 'sent'
  sent_at         DateTime?
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  employee Employee      @relation(fields: [employee_id], references: [id])
  period   PayrollPeriod @relation(fields: [period_id], references: [id])
  items    PayslipItem[]

  @@unique([employee_id, period_id])
  @@index([employee_id])
  @@index([period_id])
  @@index([status])
  @@map("payslips")
}

// Payslip Line Items (additions + deductions)
model PayslipItem {
  id          String  @id @default(uuid())
  payslip_id  String
  item_type   String  // 'addition' or 'deduction'
  item_name   String  // 'Bonus Kehadiran', 'Potongan Pinjaman', 'PPh 21', etc.
  item_category String? // 'bonus', 'allowance', 'overtime', 'tax', 'loan', 'insurance', 'other'
  amount      Decimal @db.Decimal(15, 2)
  description String?
  created_at  DateTime @default(now())

  payslip Payslip @relation(fields: [payslip_id], references: [id], onDelete: Cascade)

  @@index([payslip_id])
  @@index([item_type])
  @@map("payslip_items")
}

// Payroll Component Template (reusable addition/deduction types)
model PayrollComponent {
  id             String  @id @default(uuid())
  component_name String  @unique // 'PPh 21', 'BPJS Kesehatan', 'Bonus Kehadiran', etc.
  component_type String  // 'addition' or 'deduction'
  category       String  // 'tax', 'insurance', 'bonus', 'allowance', 'loan', 'other'
  default_amount Decimal? @db.Decimal(15, 2)
  is_percentage  Boolean @default(false)
  percentage_of  String? // 'base_salary', 'gross', null
  is_mandatory   Boolean @default(false) // always applied to all employees
  is_active      Boolean @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now())

  @@index([component_type])
  @@index([is_active])
  @@map("payroll_components")
}

// ============================================================================
// Hermes Agentic AI Integration Tables
// ============================================================================

// Hermes Action Log — audit trail of all actions performed by Hermes agents
model HermesActionLog {
  id              String   @id @default(uuid())
  agent_id        String
  action_type     String
  parameters      Json     @default("{}")
  result          Json?
  status          String   @default("success") // 'success', 'failed', 'rate_limited', 'authority_denied', 'safety_blocked'
  authority_level String
  execution_ms    Int?
  error_message   String?
  created_at      DateTime @default(now())

  @@index([agent_id])
  @@index([action_type])
  @@index([status])
  @@index([created_at])
  @@index([agent_id, status, created_at])
  @@map("hermes_action_logs")
}

// Hermes Suggestion — proposals for human review (human-in-the-loop)
model HermesSuggestion {
  id                   String    @id @default(uuid())
  agent_id             String
  action_type          String
  target_entity_id     String
  entity_type          String
  suggestion           Json      @default("{}")
  reasoning            String
  confidence           Float?
  correlation_event_id String?
  status               String    @default("pending") // 'pending', 'accepted', 'rejected', 'expired'
  reviewed_by          String?
  reviewed_at          DateTime?
  review_notes         String?
  expires_at           DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now())

  @@index([agent_id])
  @@index([status])
  @@index([entity_type])
  @@index([expires_at])
  @@index([status, expires_at])
  @@map("hermes_suggestions")
}

// Hermes Follow-Up — scheduled notifications for future delivery
model HermesFollowUp {
  id                  String    @id @default(uuid())
  agent_id            String
  recipient_id        String
  title               String
  message             String
  scheduled_at        DateTime
  context_entity_id   String?
  context_entity_type String?
  status              String    @default("pending") // 'pending', 'delivered', 'cancelled', 'failed'
  delivered_at        DateTime?
  created_at          DateTime  @default(now())

  // Relations
  recipient Employee @relation("HermesFollowUpRecipient", fields: [recipient_id], references: [id])

  @@index([agent_id])
  @@index([recipient_id])
  @@index([status])
  @@index([scheduled_at])
  @@index([status, scheduled_at])
  @@map("hermes_follow_ups")
}


// ============================================================================
// SOP (Standard Operating Procedure) Documents
// ============================================================================

model SopDocument {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String?  // e.g. 'HR', 'IT', 'Finance', 'Operations'
  file_name   String   // original file name
  file_path   String   // stored file path on disk
  file_size   Int      // in bytes
  mime_type   String   @default("application/pdf")
  uploaded_by String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  chunks SopChunk[]

  @@index([category])
  @@index([is_active])
  @@index([created_at])
  @@map("sop_documents")
}

model SopChunk {
  id              String   @id @default(uuid())
  sop_document_id String
  chunk_index     Int
  content         String
  embedding       Json?
  token_count     Int      @default(0)
  created_at      DateTime @default(now())

  document SopDocument @relation(fields: [sop_document_id], references: [id], onDelete: Cascade)

  @@unique([sop_document_id, chunk_index])
  @@index([sop_document_id])
  @@map("sop_chunks")
}

model AiAgentLog {
  id                String   @id @default(uuid())
  employee_id       String?
  session_id        String?
  channel           String   @default("whatsapp")
  user_message      String?
  assistant_message String?
  tools_called      Json     @default("[]")
  model             String?
  input_tokens      Int      @default(0)
  output_tokens     Int      @default(0)
  latency_ms        Int?
  status            String   @default("success")
  error_message     String?
  created_at        DateTime @default(now())

  employee Employee? @relation("AiAgentLogEmployee", fields: [employee_id], references: [id])

  @@index([employee_id])
  @@index([created_at])
  @@index([status])
  @@map("ai_agent_logs")
}

model AiPendingAction {
  id          String    @id @default(uuid())
  employee_id String
  session_id  String?
  action_type String
  payload     Json      @default("{}")
  summary     String
  status      String    @default("pending")
  expires_at  DateTime
  created_at  DateTime  @default(now())
  executed_at DateTime?

  employee Employee @relation("AiPendingActionEmployee", fields: [employee_id], references: [id])

  @@index([employee_id, status])
  @@index([expires_at])
  @@map("ai_pending_actions")
}


// ============================================================================
// WhatsApp Agent Integration (Kapso)
// ============================================================================

// WhatsApp Message Log — full audit trail of all messages sent/received
model WhatsAppMessageLog {
  id                   String   @id @default(uuid())
  employee_id          String
  direction            String   // 'inbound' | 'outbound'
  message_type         String   @default("text") // 'text' | 'template' | 'media' | 'interactive' | 'otp'
  content              String   // message body (encrypted at DB level)
  wa_message_id        String?  // Kapso/Meta message ID for delivery tracking
  wa_status            String   @default("sent") // 'sent' | 'delivered' | 'read' | 'failed'
  hermes_agent_id      String?  // which Hermes agent processed/sent this
  hermes_action_log_id String?  // FK link to hermes_action_logs for audit cross-reference
  session_id           String?  // FK to whatsapp_sessions
  correlation_id       String?  // groups related messages in a conversation thread
  metadata             Json?    // additional context (template params, media URLs, etc.)
  error_message        String?  // failure reason if wa_status = 'failed'
  created_at           DateTime @default(now())

  // Relations
  employee Employee         @relation("WhatsAppEmployee", fields: [employee_id], references: [id])
  session  WhatsAppSession? @relation("WhatsAppSessionMessages", fields: [session_id], references: [id])

  @@index([employee_id])
  @@index([direction])
  @@index([wa_message_id])
  @@index([session_id])
  @@index([hermes_agent_id])
  @@index([correlation_id])
  @@index([created_at])
  @@index([employee_id, direction, created_at])
  @@map("whatsapp_message_logs")
}

// WhatsApp Session — conversation session tracking
model WhatsAppSession {
  id               String    @id @default(uuid())
  employee_id      String
  started_at       DateTime  @default(now())
  ended_at         DateTime?
  last_activity_at DateTime  @default(now())
  message_count    Int       @default(0)
  hermes_agent_id  String?   // which Hermes agent is handling this session
  status           String    @default("active") // 'active' | 'idle' | 'closed'
  metadata         Json?     // session context (topic, intent, etc.)
  created_at       DateTime  @default(now())

  // Relations
  employee Employee              @relation("WhatsAppSessionEmployee", fields: [employee_id], references: [id])
  messages WhatsAppMessageLog[]  @relation("WhatsAppSessionMessages")

  @@index([employee_id])
  @@index([status])
  @@index([last_activity_at])
  @@index([employee_id, status])
  @@map("whatsapp_sessions")
}
