  deleted_at     DateTime?

  tenants     tenants           @relation(fields: [tenant_id], references: [id])
  companies   companies?        @relation(fields: [company_id], references: [id])
  departments departments?      @relation(fields: [department_id], references: [id])
  owner       users             @relation(fields: [owner_id], references: [id])
  folder      explorer_folders? @relation(fields: [folder_id], references: [id])
  last_editor users?            @relation("FileEditor", fields: [last_edited_by], references: [id])

  @@index([tenant_id])
  @@index([company_id])
  @@index([department_id])
  @@index([branch_id])
  @@index([ecommerce_id])
  @@index([owner_id])
  @@index([folder_id])
}

model explorer_notes {
  id            String    @id @default(uuid())
  tenant_id     String
  company_id    String?
  department_id String?
  owner_id      String
  title         String
  content       String    @db.Text
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now())
  deleted_at    DateTime?

  tenants     tenants      @relation(fields: [tenant_id], references: [id])
  companies   companies?   @relation(fields: [company_id], references: [id])
  departments departments? @relation(fields: [department_id], references: [id])
  owner       users        @relation(fields: [owner_id], references: [id])

  @@index([tenant_id])
  @@index([company_id])
  @@index([department_id])
}

model export_audit_trail {
  id            String   @id @default(uuid())
  tenant_id     String
  company_id    String?
  user_id       String
  forensic_code String   @unique
  ip_address    String
  timestamp     DateTime @default(now())
  metadata      Json?

  tenants tenants @relation(fields: [tenant_id], references: [id])
  users   users   @relation(fields: [user_id], references: [id])

  @@index([tenant_id])
  @@index([user_id])
  @@index([forensic_code])
}

model finance_loans {
  id            String    @id @default(uuid())
  tenant_id     String
  company_id    String?
  employee_id   String
  amount        Decimal   @db.Decimal(20, 2)
  currency      String    @default("USD")
  interest_rate Decimal   @db.Decimal(5, 2)
  term_months   Int
  start_date    DateTime
  status        String    @default("PENDING")
  purpose       String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now())
  deleted_at    DateTime?

  tenants      tenants                     @relation(fields: [tenant_id], references: [id])
  companies    companies?                  @relation(fields: [company_id], references: [id])
  employee     employees                   @relation(fields: [employee_id], references: [id])
  installments finance_loan_installments[]

  @@index([tenant_id])
  @@index([employee_id])
}

model finance_loan_installments {
  id        String    @id @default(uuid())
  loan_id   String
  due_date  DateTime
  amount    Decimal   @db.Decimal(20, 2)
  principal Decimal   @db.Decimal(20, 2)
  interest  Decimal   @db.Decimal(20, 2)
  status    String    @default("PENDING")
  paid_at   DateTime?

  loan finance_loans @relation(fields: [loan_id], references: [id])

  @@index([loan_id])
}

model inventory_import_jobs {
  id              String    @id @default(uuid())
  tenant_id       String
  user_id         String
  type            String // DATA, IMAGES
  filename        String
  file_path       String
  status          String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  total_items     Int       @default(0)
  processed_items Int       @default(0)
  error_count     Int       @default(0)
  errors          Json? // Array of { identifier, message }
  started_at      DateTime?
  completed_at    DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now())

  tenants tenants @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@index([status])
  @@index([type])
}
