# Environment variables for Zenvix Platform

# Database
DATABASE_URL="postgresql://zenvix:zenvix_dev_password@localhost:5432/zenvix_dev?schema=public"

# Node Environment
NODE_ENV="development"
PERSISTENCE_MODE="db"

# Retail public auth (JWT)
RETAIL_AUTH_JWT_SECRET="dev_retail_auth_secret_change_me"

# Enable Mock Repositories for backend development missing DB implementations
FINANCE_EXECUTION_MODE="mock"
