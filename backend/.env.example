# --- TARA Backend Environment Variables ---

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tara?schema=public"

# Security
JWT_SECRET=your-secret-key-here-change-in-production
BCRYPT_ROUNDS=12
FIELD_ENCRYPTION_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@tara.local

# SOP Document Storage
# Set to a persistent path on your VPS (e.g., /var/data/tara/sop)
# Defaults to ./uploads/sop if not set
SOP_UPLOAD_DIR=

# WhatsApp (Kapso)
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=597907523413541
KAPSO_BUSINESS_ACCOUNT_ID=2102230076919824
KAPSO_CONFIG_ID=31b31160-36d4-4468-92b6-2458fa6b949e
KAPSO_WEBHOOK_SECRET=
