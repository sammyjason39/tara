# --- TARA Backend Environment Variables ---

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tara?schema=public"

# Security
JWT_SECRET=your-secret-key-here-change-in-production
BCRYPT_ROUNDS=12
FIELD_ENCRYPTION_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@tara.local

# SOP Document Storage
# Set to a persistent path on your VPS (e.g., /var/data/tara/sop)
# Defaults to ./uploads/sop if not set
SOP_UPLOAD_DIR=

# WhatsApp (Kapso)
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=1177690982091942
KAPSO_BUSINESS_ACCOUNT_ID=1531978955225901
KAPSO_CONFIG_ID=014dc306-766f-43a3-b088-5efc73518b58
KAPSO_BUSINESS_NUMBER=+6285196416317
KAPSO_WEBHOOK_SECRET=

# Hermes Agentic AI integration
# Use a strong shared secret. Hermes sends this as X-Hermes-Api-Key.
HERMES_API_KEY=
# Ralali employee seed (CSV not in git — place file locally)
RALALI_EMPLOYEES_CSV=
SEED_PASSWORD=
# Temporary backend-only WA reply bridge for production smoke tests.
# Keep false when a real Hermes event consumer is running.
HERMES_WA_LOCAL_MVP_ENABLED=false
# Same-VPS Hermes consumer should call TARA through localhost.
TARA_API_BASE_URL=http://localhost:3001/v1
TARA_HERMES_AGENT_ID=tara-wa-agent
