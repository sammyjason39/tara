# --- TARA Backend Environment Variables ---

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:your-db-password@localhost:5432/tara?schema=public"

# Security
JWT_SECRET=your-jwt-secret-min-32-characters
BCRYPT_ROUNDS=12
FIELD_ENCRYPTION_KEY=your-field-encryption-key-here

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (SMTP)
MAIL_HOST=smtp.your-provider.example.com
MAIL_PORT=587
MAIL_USER=your-smtp-user
MAIL_PASS=your-smtp-password
MAIL_FROM=noreply@your-domain.example.com

# SOP Document Storage
SOP_UPLOAD_DIR=/var/data/tara/sop

# WhatsApp (Kapso)
KAPSO_API_KEY=your-kapso-api-key-here
KAPSO_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
KAPSO_BUSINESS_ACCOUNT_ID=your-whatsapp-business-account-id
KAPSO_CONFIG_ID=your-kapso-config-uuid
KAPSO_BUSINESS_NUMBER=+62xxxxxxxxxx
KAPSO_WEBHOOK_SECRET=your-kapso-webhook-secret-here

# Hermes Agentic AI integration
HERMES_API_KEY=your-hermes-api-key-here

# Ralali employee seed (CSV not in git — place file locally)
RALALI_EMPLOYEES_CSV=/path/to/employees.csv
SEED_PASSWORD=your-seed-password-here

# Temporary backend-only WA reply bridge for smoke tests
HERMES_WA_LOCAL_MVP_ENABLED=false
TARA_API_BASE_URL=http://localhost:3001/v1
TARA_HERMES_AGENT_ID=your-hermes-agent-id

# TARA AI Assistant
AI_API_KEY=your-openrouter-api-key-here
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=your-model-id-here
AI_HR_ESCALATION_EMAIL=hr@your-company.example.com
