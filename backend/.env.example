# --- Backend Production Environment Variables ---

# Server Port (Render sets this automatically, but local prod uses 3001)
PORT=3001

# Application Mode
NODE_ENV=production
PERSISTENCE_MODE=mock

# Security
# Set this to a long random string (e.g., openssl rand -base64 32)
JWT_SECRET=
RETAIL_AUTH_JWT_SECRET=

# CORS
# The URL of your deployed frontend (e.g., https://zenvix-frontend.onrender.com)
# For multiple origins, separate by comma: https://site1.com,https://site2.com
ALLOWED_ORIGINS=
