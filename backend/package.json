{
  "name": "tara-backend",
  "version": "2.0.8",
  "description": "TARA — Total Assistance for Resources & Administration (Backend)",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "ts-node src/scripts/seed-defaults.ts",
    "seed:ralali": "ts-node src/scripts/seed-ralali-employees.ts",
    "seed:ralali:prod": "node dist/scripts/seed-ralali-employees.js",
    "seed:leave-xlsx": "ts-node src/scripts/seed-leave-balances-xlsx.ts",
    "seed:leave-xlsx:dry": "ts-node src/scripts/seed-leave-balances-xlsx.ts --dry-run",
    "seed:leave-xlsx:prod": "node dist/scripts/seed-leave-balances-xlsx.js",
    "test:ai-e2e": "NODE_OPTIONS='--max-old-space-size=8192' ts-node -r tsconfig-paths/register src/scripts/test-ai-e2e.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@azure/identity": "^4.13.1",
    "@azure/search-documents": "^13.0.0",
    "@google/genai": "^2.10.0",
    "@kapso/whatsapp-cloud-api": "^0.2.2",
    "@langchain/core": "^1.2.1",
    "@langchain/openai": "^1.5.3",
    "@mistralai/mistralai": "^2.3.0",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/client": "6.2.1",
    "@qdrant/js-client-rest": "^1.18.0",
    "@supabase/supabase-js": "^2.108.2",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudflare": "^6.5.0",
    "compromise": "^14.15.1",
    "dotenv": "^17.3.1",
    "eventemitter2": "^6.4.9",
    "groq-sdk": "^1.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.5.2",
    "mem0ai": "^3.0.10",
    "natural": "^8.1.1",
    "ollama": "^0.6.3",
    "pdf-parse": "^2.4.5",
    "pg": "^8.19.0",
    "redis": "^6.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.56.0",
    "fast-check": "^4.8.0",
    "jest": "^30.4.2",
    "prettier": "^3.2.4",
    "prisma": "6.2.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
